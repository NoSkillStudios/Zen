-- ║              EXPANDED CARD (CLOSE RANGE)                  ║
-- ╚════════════════════════════════════════════════════════════╝
local function ui_big(b,plr,isOwner)
	clear(b)
	b.Size=UDim2.fromOffset(180,60)
	
	local accentColor=isOwner and COLORS.owner_main or COLORS.user_main
	local accentDark=isOwner and COLORS.owner_dark or COLORS.user_dark
	
	-- Outer glow effect
	local glowFrame=Instance.new("Frame",b)
	glowFrame.Name="Glow"
	glowFrame.Size=UDim2.fromScale(1,1)
	glowFrame.BackgroundColor3=accentColor
	glowFrame.BackgroundTransparency=0.85
	glowFrame.BorderSizePixel=0
	local glowCorner=Instance.new("UICorner",glowFrame)
	glowCorner.CornerRadius=UDim.new(0,12)
	
	-- Main card container
	local card=Instance.new("Frame",b)
	card.Name="Card"
	card.Size=UDim2.fromScale(1,1)
	card.BackgroundColor3=COLORS.bg_dark
	card.BackgroundTransparency=0.1
	card.BorderSizePixel=0
	local cardCorner=Instance.new("UICorner",card)
	cardCorner.CornerRadius=UDim.new(0,12)
	
	-- Background gradient
	local cardGrad=createGradient(card,135)
	cardGrad.Color=ColorSequence.new({
		ColorSequenceKeypoint.new(0,Color3.fromRGB(20,18,25)),
		ColorSequenceKeypoint.new(1,Color3.fromRGB(15,14,20)),
	})
	
	-- Premium stroke
	local stroke=Instance.new("UIStroke",card)
	stroke.Color=accentColor
	stroke.Thickness=2
	stroke.Transparency=0.2
	
	-- Top accent bar with gradient
	local topBar=Instance.new("Frame",card)
	topBar.Name="TopBar"
	topBar.Size=UDim2.new(1,0,0,3)
	topBar.BackgroundColor3=accentColor
	topBar.BorderSizePixel=0
	local barGrad=createGradient(topBar,0)
	barGrad.Color=ColorSequence.new({
		ColorSequenceKeypoint.new(0,accentDark),
		ColorSequenceKeypoint.new(0.5,accentColor),
		ColorSequenceKeypoint.new(1,accentDark),
	})
	
	-- Left accent stripe (thin glowing bar)
	local leftStripe=Instance.new("Frame",card)
	leftStripe.Name="LeftStripe"
	leftStripe.Size=UDim2.new(0,3,1,-6)
	leftStripe.Position=UDim2.new(0,5,0,3)
	leftStripe.BackgroundColor3=accentColor
	leftStripe.BorderSizePixel=0
	local stripeCorner=Instance.new("UICorner",leftStripe)
	stripeCorner.CornerRadius=UDim.new(0,2)
	local stripeGrad=createGradient(leftStripe,90)
	stripeGrad.Color=ColorSequence.new({
		ColorSequenceKeypoint.new(0,accentColor),
		ColorSequenceKeypoint.new(0.5,accentColor),
		ColorSequenceKeypoint.new(1,Color3.fromRGB(100,60,20)),
	})
	
	-- Icon container
	local iconBox=Instance.new("Frame",card)
	iconBox.Name="IconBox"
	iconBox.Size=UDim2.fromOffset(40,60)
	iconBox.Position=UDim2.fromOffset(8,0)
	iconBox.BackgroundTransparency=1
	local iconLabel=Instance.new("TextLabel",iconBox)
	iconLabel.Size=UDim2.fromScale(1,1)
	iconLabel.BackgroundTransparency=1
	iconLabel.Text=isOwner and "🌺" or "🌸"
	iconLabel.TextSize=24
	iconLabel.Font=Enum.Font.Gotham
	iconLabel.TextColor3=accentColor
	
	-- Content container
	local contentBox=Instance.new("Frame",card)
	contentBox.Name="Content"
	contentBox.Size=UDim2.new(1,-56,1,-6)
	contentBox.Position=UDim2.fromOffset(48,3)
	contentBox.BackgroundTransparency=1
	contentBox.BorderSizePixel=0
	
	-- Username label
	local nameLabel=Instance.new("TextLabel",contentBox)
	nameLabel.Name="Name"
	nameLabel.Size=UDim2.fromScale(1,0.45)
	nameLabel.BackgroundTransparency=1
	nameLabel.Text=plr.Name
	nameLabel.TextScaled=true
	nameLabel.Font=Enum.Font.GothamBold
	nameLabel.TextColor3=COLORS.text
	nameLabel.TextXAlignment=Enum.TextXAlignment.Left
	nameLabel.TextYAlignment=Enum.TextYAlignment.Bottom
	nameLabel.TextTruncate=Enum.TextTruncate.AtEnd
	
	-- Status badge
	local statusLabel=Instance.new("TextLabel",contentBox)
	statusLabel.Name="Status"
	statusLabel.Size=UDim2.fromScale(1,0.55)
	statusLabel.Position=UDim2.fromOffset(0,24)
	statusLabel.BackgroundTransparency=1
	statusLabel.Text=isOwner and "👑 OWNER" or "🌱 USER"
	statusLabel.TextScaled=true
	statusLabel.Font=Enum.Font.GothamBold
	statusLabel.TextColor3=accentColor
	statusLabel.TextXAlignment=Enum.TextXAlignment.Left
	statusLabel.TextYAlignment=Enum.TextYAlignment.Top
	
	state[plr.Name]=true
end

