local k = "NihonLoader_Key_Real"
getgenv()._nl = k

local GAMES = {
	["7398552394"]      = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
	["125224440903394"] = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
	["90568084448279"]  = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap",
}

local pid = tostring(game.PlaceId)
if not GAMES[pid] then
	game:GetService("Players").LocalPlayer:Kick("🌺 Nihon Hub — This game is not supported.")
	return
end

local function load_script(url)
	local ok, data = pcall(game.HttpGet, game, url)
	if not ok or not data or #data == 0 then
		return nil
	end
	
	local ok2, fn = pcall(loadstring, data)
	if not ok2 or not fn then
		return nil
	end
	
	local ok3, module = pcall(fn)
	if not ok3 or not module then
		return nil
	end
	
	if module._ok ~= true then
		return nil
	end
	
	return module
end

local v = tostring(math.random(10000000, 99999999))
local secUrl = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/SecondScript?v=" .. v
local gameUrl = GAMES[pid] .. "?v=" .. v

local sec = load_script(secUrl)
local main = load_script(gameUrl)

if not sec then
	error("Loader error: SecondScript failed to load.")
	return
end

if not main then
	error("Loader error: Game script failed to load.")
	return
end

if sec.init and type(sec.init) == "function" then
	pcall(sec.init)
end

if main.init and type(main.init) == "function" then
	pcall(main.init)
end
