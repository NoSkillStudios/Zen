local k = "NihonLoader_Key_Real"
getgenv()._nl = k

local function ld(u)
	local s, r = pcall(function()
		return loadstring(game:HttpGet(u))()
	end)
	if not s or not r then return nil end
	return r
end

local b = ld("https://raw.githubusercontent.com/NoSkillStudios/Zen/main/SecondScript")
if not b then error("Loader error: SecondScript failed to load.") return end
if not b._ok then error("Loader error: SecondScript validation failed.") return end
if b.init then b.init() end

