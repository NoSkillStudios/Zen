	for plr in pairs(espBoards) do destroyESPFor(plr) end
end
local function buildESPFor(plr)
	if plr == lp then return end
	destroyESPFor(plr)
	local char = plr.Character; if not char then return end
	local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	if not head then return end
	local data = { char=char }
	local col  = espColor
	if espOutline or espBox then
		local hl = Instance.new("Highlight")
		hl.Name = "NihonESP"
		hl.FillTransparency = espBox and (0.75+espTransparency*0.25) or 1
		if espBox then hl.FillColor = col end
		hl.OutlineColor = col; hl.OutlineTransparency = espTransparency
		hl.DepthMode = espAlwaysOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
		hl.Parent = char; data.hl = hl
	end
	if espBones then
		data.bones = {}
		local joints = {
			{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
			{"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},
			{"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},
			{"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},
			{"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},
			{"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},
			{"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"},
		}
		for _, pair in ipairs(joints) do
			local line = Drawing.new("Line")
			line.Color=col; line.Thickness=1.5; line.Transparency=espTransparency; line.Visible=false
			table.insert(data.bones, { line=line, a=pair[1], b=pair[2] })
		end
	end
	if espTracers then
		local line = Drawing.new("Line")
		line.Color=col; line.Thickness=1.2; line.Transparency=espTransparency; line.Visible=false
		data.tracer = line
	end
	if espNames or espHP or espDist then
		local bb = Instance.new("BillboardGui")
		bb.Name="NihonESPTag"; bb.Adornee=head; bb.AlwaysOnTop=espAlwaysOnTop
		bb.Size=UDim2.fromOffset(120,44); bb.StudsOffset=Vector3.new(0,2.8,0)
		bb.ResetOnSpawn=false; bb.Parent=head
		local card = Instance.new("Frame",bb)
		card.Size=UDim2.fromScale(1,1); card.BackgroundColor3=BLOOM.bgDeep
		card.BackgroundTransparency=0.28; card.BorderSizePixel=0
		Instance.new("UICorner",card).CornerRadius=UDim.new(0,6)
		local sk=Instance.new("UIStroke",card); sk.Color=col; sk.Thickness=1.2; sk.Transparency=0.05
		local nl=Instance.new("TextLabel",card)
		nl.Name="NameLbl"; nl.Size=UDim2.new(1,-8,0,18); nl.Position=UDim2.fromOffset(4,2)
		nl.BackgroundTransparency=1; nl.TextColor3=col; nl.Font=Enum.Font.GothamBold; nl.TextSize=11
		nl.TextXAlignment=Enum.TextXAlignment.Center; nl.TextTruncate=Enum.TextTruncate.AtEnd
		nl.Text="🌼 "..plr.Name; nl.Visible=espNames
		local barBg=Instance.new("Frame",card)
		barBg.Name="BarBg"; barBg.Size=UDim2.new(1,-10,0,5); barBg.Position=UDim2.new(0,5,0,23)
		barBg.BackgroundColor3=BLOOM.bar; barBg.BorderSizePixel=0
		Instance.new("UICorner",barBg).CornerRadius=UDim.new(1,0)
		local bf=Instance.new("Frame",barBg)
		bf.Name="Fill"; bf.Size=UDim2.fromScale(1,1); bf.BackgroundColor3=col; bf.BorderSizePixel=0
		Instance.new("UICorner",bf).CornerRadius=UDim.new(1,0)
		barBg.Visible=espHP
		local hpLbl=Instance.new("TextLabel",card)
		hpLbl.Name="HP"; hpLbl.Size=UDim2.new(1,-8,0,11); hpLbl.Position=UDim2.new(0,4,0,30)
		hpLbl.BackgroundTransparency=1; hpLbl.TextColor3=BLOOM.txtMain
		hpLbl.Font=Enum.Font.Gotham; hpLbl.TextSize=9
		hpLbl.TextXAlignment=Enum.TextXAlignment.Center; hpLbl.Text="HP: ?"; hpLbl.Visible=espHP
		data.bb = bb
	end
	espBoards[plr] = data
end
local function rebuildESP()
	if not espEnabled then return end
	for plr in pairs(espBoards) do destroyESPFor(plr) end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character then buildESPFor(plr) end
	end
end
local function updateESPFor(plr)
	local data = espBoards[plr]; if not data then return end
	local char = data.char
	if not char or not char.Parent then destroyESPFor(plr); return end
	local hum  = char:FindFirstChildWhichIsA("Humanoid")
	local hrpT = char:FindFirstChild("HumanoidRootPart")
	local hrpL = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
	if data.bb and data.bb.Parent then
		local card = data.bb:FindFirstChildWhichIsA("Frame")
		if card then
			local nl    = card:FindFirstChild("NameLbl")
			local barBg = card:FindFirstChild("BarBg"); local fill = barBg and barBg:FindFirstChild("Fill")
			local hpLbl = card:FindFirstChild("HP")
			if nl then
				nl.Visible = espNames
				nl.Text = (espDist and hrpL and hrpT)
					and ("🌼 "..plr.Name.."  ["..math.floor((hrpL.Position-hrpT.Position).Magnitude).."m]")
					or  ("🌼 "..plr.Name)
			end
			if fill and hpLbl and hum then
				barBg.Visible=espHP; hpLbl.Visible=espHP
				local r=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
				fill.Size=UDim2.fromScale(r,1)
				fill.BackgroundColor3=Color3.new(math.clamp(2*(1-r),0,1),math.clamp(2*r,0,1),0.05)
				hpLbl.Text="HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth)
			end
		end
	end
	if data.bones then
		for _, d in ipairs(data.bones) do
			local pA=char:FindFirstChild(d.a); local pB=char:FindFirstChild(d.b)
			if espBones and pA and pB then
				local sA,onA=cam:WorldToViewportPoint(pA.Position)
				local sB,onB=cam:WorldToViewportPoint(pB.Position)
				if onA and onB and sA.Z>0 and sB.Z>0 then
					d.line.From=Vector2.new(sA.X,sA.Y); d.line.To=Vector2.new(sB.X,sB.Y)
					d.line.Color=espColor; d.line.Visible=true
				else d.line.Visible=false end
			else d.line.Visible=false end
		end
	end
	if data.tracer then
		if espTracers and hrpT then
			local sT,onT=cam:WorldToViewportPoint(hrpT.Position)
			if onT and sT.Z>0 then
				local vp=cam.ViewportSize
				data.tracer.From=Vector2.new(vp.X/2,vp.Y)
				data.tracer.To=Vector2.new(sT.X,sT.Y)
				data.tracer.Color=espColor; data.tracer.Visible=true
			else data.tracer.Visible=false end
		else data.tracer.Visible=false end
	end
end

-- Player mechanics
local flyEnabled=false; local flySpeed=50
local noclipEnabled=false; local ghostEnabled=false
local freecamEnabled=false; local gravityEnabled=false; local gravityScale=1
local infJump=false; local flingEnabled=false; local flingRange=15
local flyConn,noclipConn,freecamConn=nil,nil,nil

local function stopFly()
	if flyConn then flyConn:Disconnect(); flyConn=nil end
	local c=lp.Character; if not c then return end
	local hrp=c:FindFirstChild("HumanoidRootPart"); local hum=c:FindFirstChild("Humanoid")
	if hrp then hrp.Velocity=Vector3.zero end
	if hum then hum.PlatformStand=false end
end
local function startFly()
	stopFly()
	local c=lp.Character; if not c then return end
	local hrp=c:FindFirstChild("HumanoidRootPart"); local hum=c:FindFirstChild("Humanoid")
	if not hrp or not hum then return end
	hum.PlatformStand=true
	flyConn=RunService.RenderStepped:Connect(function()
		if not flyEnabled then stopFly(); return end
		local dir=Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir+=cam.CFrame.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir-=cam.CFrame.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir-=cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir+=cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir+=Vector3.new(0,1,0)     end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir-=Vector3.new(0,1,0)     end
		hrp.Velocity=dir.Magnitude>0 and dir.Unit*flySpeed or Vector3.zero
		hrp.CFrame=CFrame.new(hrp.Position,hrp.Position+cam.CFrame.LookVector)
	end)
end
local function stopNoclip()
	if noclipConn then noclipConn:Disconnect(); noclipConn=nil end
	local c=lp.Character; if not c then return end
	for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end
end
local function startNoclip()
	stopNoclip()
	noclipConn=RunService.Stepped:Connect(function()
		if not noclipEnabled then stopNoclip(); return end
		local c=lp.Character; if not c then return end
		for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
	end)
end
local function setGhost(v)
	local c=lp.Character; if not c then return end
	for _,p in ipairs(c:GetDescendants()) do
		if p:IsA("BasePart") then p.CanCollide=not v; p.Transparency=v and 0.6 or 0 end
	end
	local hum=c:FindFirstChild("Humanoid"); if hum then hum.PlatformStand=false end
end
local freecamCF=CFrame.new()
local function stopFreecam()
	if freecamConn then freecamConn:Disconnect(); freecamConn=nil end
	cam.CameraType=Enum.CameraType.Custom
	cam.CameraSubject=lp.Character and lp.Character:FindFirstChild("Humanoid")
end
local function startFreecam()
	stopFreecam(); cam.CameraType=Enum.CameraType.Scriptable; freecamCF=cam.CFrame
	freecamConn=RunService.RenderStepped:Connect(function(dt)
		if not freecamEnabled then stopFreecam(); return end
		local d=Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then d+=freecamCF.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then d-=freecamCF.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then d-=freecamCF.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then d+=freecamCF.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then d+=Vector3.new(0,1,0)    end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then d-=Vector3.new(0,1,0)    end
		if d.Magnitude>0 then freecamCF=CFrame.new(freecamCF.Position+d.Unit*40*dt)*(freecamCF-freecamCF.Position) end
		local delta=UserInputService:GetMouseDelta()
		freecamCF=freecamCF*CFrame.Angles(0,-delta.X*0.003,0)*CFrame.Angles(-delta.Y*0.003,0,0)
		cam.CFrame=freecamCF
	end)
end

-- Hooks for respawn
local function hookPlayer(plr)
	plr.CharacterAdded:Connect(function(char)
		char:WaitForChild("HumanoidRootPart", 6); task.wait(0.6)
		if espEnabled then destroyESPFor(plr); buildESPFor(plr) end
		if hitboxEnabled then hitbox_orig[plr]=nil; hb_extend(plr) end
	end)
	if plr.Character then
		task.defer(function()
			if espEnabled then buildESPFor(plr) end
			if hitboxEnabled then hb_extend(plr) end
		end)
	end
end
Players.PlayerAdded:Connect(hookPlayer)
Players.PlayerRemoving:Connect(function(plr) destroyESPFor(plr); hb_restore(plr) end)
for _, plr in ipairs(Players:GetPlayers()) do if plr ~= lp then hookPlayer(plr) end end
lp.CharacterAdded:Connect(function()
	task.wait(1)
	if ghostEnabled  then setGhost(true) end
	if flyEnabled    then startFly()     end
	if noclipEnabled then startNoclip()  end
end)

