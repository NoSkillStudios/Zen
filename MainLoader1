local k="NihonLoader_Key_Real"
getgenv()._nl=k

repeat task.wait() until game and game.PlaceId

local p=game:GetService("Players")
local lp=p.LocalPlayer

local G={
[7398552394]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
[125224440903394]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
[3286380229]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/UnnamedShooter",
[17887390746]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/UnnamedShooter",
[9294074907]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap",
[90568084448279]="https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap",
}

local pid=game.PlaceId
local url=G[pid]

-- fallback check (string just in case)
if not url then
url=G[tonumber(pid)] or G[tostring(pid)]
end

if not url then
warn("Unsupported PlaceId:",pid)
lp:Kick("Nihon Hub — This game is not supported.")
return
end

local function ld(u)
local ok,res=pcall(function()
return loadstring(game:HttpGet(u))()
end)

if not ok then
warn("Load failed:",u)
return nil
end

return res
end

local a=ld("https://raw.githubusercontent.com/NoSkillStudios/Zen/main/SecondScript?v="..math.random(1,9999))
local b=ld(url.."?v="..math.random(1,9999))

if not a or not b then
error("Loader error: script fetch failed.")
return
end

if not a._ok or not b._ok then
error("Loader error: validation failed.")
return
end

task.spawn(function()
if a.init then a.init() end
end)

task.spawn(function()
if b.init then b.init() end
end)
