local function mkBtn(parent, yPos, txt, w, xOff)
	local b = Instance.new("TextButton", parent)
	b.Size = w and UDim2.fromOffset(w, 34) or UDim2.new(1, 0, 0, 30)
	b.Position = (w and xOff) and UDim2.fromOffset(xOff, yPos) or UDim2.fromOffset(0, yPos)
	b.BackgroundColor3 = Color3.fromRGB(200, 100, 30)
	b.BorderSizePixel = 0; b.AutoButtonColor = false
	b.TextColor3 = Color3.fromRGB(18, 9, 3)
	b.Font = Enum.Font.GothamBold; b.TextSize = 12; b.Text = txt
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
	local g = Instance.new("UIGradient", b)
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(240, 140, 55)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(195, 85, 20)),
	})
b.MouseEnter:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.13), {BackgroundColor3=Color3.fromRGB(230, 130, 50)}):Play()
		local hs = Instance.new("Sound")
		hs.SoundId = "rbxassetid://92876108656319"; hs.Volume = 0.4
		hs.Parent = workspace; hs:Play()
		game:GetService("Debris"):AddItem(hs, 2)
	end)
	b.MouseLeave:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.13), {BackgroundColor3=Color3.fromRGB(200, 100, 30)}):Play()
	end)
	return b
end

