local k="NihonLoader_Key_Real"
if getgenv()._nl~=k then return end

local p=game:GetService("Players")
local r=game:GetService("RunService")
local t=game:GetService("TweenService")

local lp=p.LocalPlayer
local OWNER="SkibidihhhToiwet"

local users={}
users[lp.Name]=true

local boards={}
local state={}

local EXPAND=35

local function tw(o,p2,v,d)
local i=TweenInfo.new(d,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
local tw=t:Create(o,i,{[p2]=v})
tw:Play()
return tw
end

local function clear(b)
for _,v in pairs(b:GetChildren()) do
pcall(function()v:Destroy()end)
end
end

local function ui_big(b,plr,isOwner)
clear(b)

b.Size=UDim2.fromOffset(150,50)

local c=Instance.new("Frame",b)
c.Size=UDim2.fromScale(1,1)
c.BackgroundColor3=Color3.fromRGB(20,20,20)
c.BackgroundTransparency=0.2
c.BorderSizePixel=0

local cr=Instance.new("UICorner",c)
cr.CornerRadius=UDim.new(0,8)

local s=Instance.new("UIStroke",c)
s.Thickness=1.5
s.Color=isOwner and Color3.fromRGB(255,200,100) or Color3.fromRGB(255,120,120)

local name=Instance.new("TextLabel",c)
name.Size=UDim2.fromScale(1,0.6)
name.BackgroundTransparency=1
name.Text=plr.Name
name.TextScaled=true
name.Font=Enum.Font.GothamBold
name.TextColor3=Color3.new(1,1,1)

local tag=Instance.new("TextLabel",c)
tag.Position=UDim2.fromScale(0,0.55)
tag.Size=UDim2.fromScale(1,0.45)
tag.BackgroundTransparency=1
tag.Text=isOwner and "👑 OWNER" or "🌸 USER"
tag.TextScaled=true
tag.Font=Enum.Font.Gotham
tag.TextColor3=s.Color

state[plr.Name]=true
end

local function ui_small(b,isOwner)
clear(b)

b.Size=UDim2.fromOffset(26,26)

local c=Instance.new("Frame",b)
c.Size=UDim2.fromScale(1,1)
c.BackgroundColor3=Color3.fromRGB(20,20,20)
c.BackgroundTransparency=0.2
c.BorderSizePixel=0

local cr=Instance.new("UICorner",c)
cr.CornerRadius=UDim.new(1,0)

local s=Instance.new("UIStroke",c)
s.Thickness=1.5
s.Color=isOwner and Color3.fromRGB(255,200,100) or Color3.fromRGB(255,120,120)

state[b.Name]=false
end

local function create(plr,char)
if plr==lp then return end
if not users[plr.Name] then return end

local hrp=char:FindFirstChild("HumanoidRootPart")
if not hrp then return end

if boards[plr.Name] then
boards[plr.Name]:Destroy()
end

local isOwner=plr.Name==OWNER

local b=Instance.new("BillboardGui")
b.Name=plr.Name
b.Adornee=hrp
b.Size=UDim2.fromOffset(150,50)
b.StudsOffset=Vector3.new(0,3,0)
b.AlwaysOnTop=true
b.MaxDistance=120
b.LightInfluence=0
b.Parent=hrp

ui_big(b,plr,isOwner)

boards[plr.Name]=b
end

for _,v in pairs(p:GetPlayers()) do
if v~=lp then
if v.Character then create(v,v.Character) end
v.CharacterAdded:Connect(function(c)
create(v,c)
end)
end
end

p.PlayerAdded:Connect(function(v)
if v~=lp then
v.CharacterAdded:Connect(function(c)
create(v,c)
end)
end
end)

p.PlayerRemoving:Connect(function(v)
if boards[v.Name] then
boards[v.Name]:Destroy()
boards[v.Name]=nil
end
end)

r.RenderStepped:Connect(function()
local ch=lp.Character
local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
if not hrp then return end

for n,b in pairs(boards) do
local plr=p:FindFirstChild(n)
if plr and plr.Character then
local t_hrp=plr.Character:FindFirstChild("HumanoidRootPart")
if t_hrp then
local d=(hrp.Position-t_hrp.Position).Magnitude
local isOwner=plr.Name==OWNER

if d<EXPAND and not state[n] then
ui_big(b,plr,isOwner)
elseif d>=EXPAND and state[n] then
ui_small(b,isOwner)
end
end
end
end
end)
