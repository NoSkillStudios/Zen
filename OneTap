--   PLAYER MECHANICS
-- ════════════════════════════════════════════
local flyEnabled     = false
local flySpeed       = 50
local noclipEnabled  = false
local ghostEnabled   = false
local freecamEnabled = false
local gravityEnabled = false
local gravityScale   = 1
local infJump        = false
local killAuraOn     = false
local killAuraRange  = 20
local flingEnabled   = false
local flingRange     = 15

local flyConn, noclipConn, freecamConn = nil, nil, nil
local freecamCF = CFrame.new()

local function stopFly()
	if flyConn then flyConn:Disconnect(); flyConn = nil end
	local c = lp.Character; if not c then return end
	local hrp = c:FindFirstChild("HumanoidRootPart")
	local hum = c:FindFirstChild("Humanoid")
	if hrp then hrp.Velocity = Vector3.zero end
	if hum then hum.PlatformStand = false end
end

local function startFly()
	stopFly()
	local c = lp.Character; if not c then return end
	local hrp = c:FindFirstChild("HumanoidRootPart")
	local hum = c:FindFirstChild("Humanoid")
	if not hrp or not hum then return end
	hum.PlatformStand = true
	local cam = workspace.CurrentCamera
	flyConn = RunService.RenderStepped:Connect(function()
		if not flyEnabled then stopFly(); return end
		local dir = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir += cam.CFrame.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir -= cam.CFrame.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir -= cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir += cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir += Vector3.new(0,1,0)     end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0,1,0)     end
		hrp.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.zero
		hrp.CFrame   = CFrame.new(hrp.Position, hrp.Position + cam.CFrame.LookVector)
	end)
end

local function stopNoclip()
	if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
	local c = lp.Character; if not c then return end
	for _, p in ipairs(c:GetDescendants()) do
		if p:IsA("BasePart") then p.CanCollide = true end
	end
end

local function startNoclip()
	stopNoclip()
	noclipConn = RunService.Stepped:Connect(function()
		if not noclipEnabled then stopNoclip(); return end
		local c = lp.Character; if not c then return end
		for _, p in ipairs(c:GetDescendants()) do
			if p:IsA("BasePart") then p.CanCollide = false end
		end
	end)
end

local function setGhost(v)
	local c = lp.Character; if not c then return end
	for _, p in ipairs(c:GetDescendants()) do
		if p:IsA("BasePart") then
			p.CanCollide   = not v
			p.Transparency = v and 0.6 or 0
		end
	end
	local hum = c:FindFirstChild("Humanoid")
	if hum then hum.PlatformStand = false end
end

local function stopFreecam()
	if freecamConn then freecamConn:Disconnect(); freecamConn = nil end
	workspace.CurrentCamera.CameraType    = Enum.CameraType.Custom
	workspace.CurrentCamera.CameraSubject = lp.Character and lp.Character:FindFirstChild("Humanoid")
end

local function startFreecam()
	stopFreecam()
	local cam = workspace.CurrentCamera
	cam.CameraType = Enum.CameraType.Scriptable
	freecamCF = cam.CFrame
	freecamConn = RunService.RenderStepped:Connect(function(dt)
		if not freecamEnabled then stopFreecam(); return end
		local d = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then d += freecamCF.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then d -= freecamCF.LookVector  end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then d -= freecamCF.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then d += freecamCF.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then d += Vector3.new(0,1,0)    end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then d -= Vector3.new(0,1,0)    end
		if d.Magnitude > 0 then
			freecamCF = CFrame.new(freecamCF.Position + d.Unit * 40 * dt) * (freecamCF - freecamCF.Position)
		end
		local delta = UserInputService:GetMouseDelta()
		freecamCF = freecamCF * CFrame.Angles(0,-delta.X*0.003,0) * CFrame.Angles(-delta.Y*0.003,0,0)
		cam.CFrame = freecamCF
	end)
end

-- Hooks
Players.PlayerRemoving:Connect(function(plr)
	destroyESPFor(plr)
	restoredPart(plr)
	hitbox_orig[plr] = nil
end)

Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(function()
		task.wait(0.5)
