local keyPassed = false

if keyRequired then
	if isOwner then
		keyPassed = true
		task.wait(0.05)
		slideOut(KeyPanel, LoadPanel)
	else
		local attempts = 0
		local function shakeBox()
			local orig = KeyBox.Position
			for _ = 1, 4 do
				TweenService:Create(KeyBox, TweenInfo.new(0.04), {Position=orig+UDim2.fromOffset(6,0)}):Play(); task.wait(0.04)
				TweenService:Create(KeyBox, TweenInfo.new(0.04), {Position=orig+UDim2.fromOffset(-6,0)}):Play(); task.wait(0.04)
			end
			TweenService:Create(KeyBox, TweenInfo.new(0.04), {Position=orig}):Play()
		end
		local function tryKey()
			if keyPassed then return end
			playSound("rbxassetid://139009780109934")
			local input = KeyBox.Text
			local valid = false
			for _, kv in ipairs(VALID_KEYS) do if input == kv then valid = true; break end end
			if valid then
				keyPassed = true
				TweenService:Create(kbStroke, TweenInfo.new(0.15), {Color=BLOOM.keyOk}):Play()
				TweenService:Create(KeyBox, TweenInfo.new(0.15), {TextColor3=BLOOM.keyOk}):Play()
