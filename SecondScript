local function ui_small(b,isOwner)
	clear(b)
	b.Size=UDim2.fromOffset(32,32)
	
	local accentColor=isOwner and COLORS.owner_main or COLORS.user_main
	
	-- Outer glow
	local glowFrame=Instance.new("Frame",b)
	glowFrame.Name="Glow"
	glowFrame.Size=UDim2.fromScale(1,1)
	glowFrame.BackgroundColor3=accentColor
	glowFrame.BackgroundTransparency=0.8
	glowFrame.BorderSizePixel=0
	local glowCorner=Instance.new("UICorner",glowFrame)
	glowCorner.CornerRadius=UDim.new(1,0)
	
	-- Main circle
	local circle=Instance.new("Frame",b)
	circle.Name="Circle"
	circle.Size=UDim2.fromScale(1,1)
	circle.BackgroundColor3=COLORS.bg_dark
	circle.BackgroundTransparency=0.15
	circle.BorderSizePixel=0
	local circleCorner=Instance.new("UICorner",circle)
	circleCorner.CornerRadius=UDim.new(1,0)
	
	-- Circle stroke
	local stroke=Instance.new("UIStroke",circle)
	stroke.Color=accentColor
	stroke.Thickness=2
	stroke.Transparency=0.15
	
	-- Inner pulsing dot
	local dot=Instance.new("Frame",circle)
	dot.Name="Dot"
	dot.Size=UDim2.fromOffset(8,8)
	dot.AnchorPoint=Vector2.new(0.5,0.5)
	dot.Position=UDim2.fromScale(0.5,0.5)
	dot.BackgroundColor3=accentColor
	dot.BorderSizePixel=0
	local dotCorner=Instance.new("UICorner",dot)
	dotCorner.CornerRadius=UDim.new(1,0)
	
	-- Pulse animation
	task.spawn(function()
		while circle and circle.Parent do
			tw(dot,"Size",UDim2.fromOffset(11,11),0.6)
			task.wait(0.6)
			tw(dot,"Size",UDim2.fromOffset(8,8),0.6)
			task.wait(0.6)
		end
	end)
	
	state[b.Name]=false
end

local function create(plr,char)
	if plr==lp then return end
	if not users[plr.Name] then return end
	local hrp=char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	if boards[plr.Name] then
		boards[plr.Name]:Destroy()
	end
	local isOwner=plr.Name==OWNER
	local b=Instance.new("BillboardGui")
	b.Name=plr.Name
	b.Adornee=hrp
	b.Size=UDim2.fromOffset(180,60)
	b.StudsOffset=Vector3.new(0,3.5,0)
	b.AlwaysOnTop=true
	b.MaxDistance=150
	b.LightInfluence=0
	b.ResetOnSpawn=false
	b.Parent=hrp
	ui_big(b,plr,isOwner)
	boards[plr.Name]=b
	print("✅ Created tag: "..plr.Name..(isOwner and " (OWNER)" or " (USER)"))
end

-- Connect to all players
for _,v in pairs(p:GetPlayers()) do
	if v~=lp then
		users[v.Name]=true
		if v.Character then create(v,v.Character) end
		v.CharacterAdded:Connect(function(c)
			create(v,c)
		end)
	end
end

p.PlayerAdded:Connect(function(v)
	if v~=lp then
		users[v.Name]=true
		if v.Character then create(v,v.Character) end
		v.CharacterAdded:Connect(function(c)
			create(v,c)
		end)
	end
end)

p.PlayerRemoving:Connect(function(v)
	if boards[v.Name] then
		boards[v.Name]:Destroy()
		boards[v.Name]=nil
	end
	users[v.Name]=nil
end)

-- Main distance update loop
r.RenderStepped:Connect(function()
	local ch=lp.Character
	local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	for n,b in pairs(boards) do
		if b and b.Parent then
			local plr=p:FindFirstChild(n)
			if plr and plr.Character then
				local t_hrp=plr.Character:FindFirstChild("HumanoidRootPart")
				if t_hrp then
					local d=(hrp.Position-t_hrp.Position).Magnitude
					local isOwner=plr.Name==OWNER
					if d<EXPAND and not state[n] then
						tw(b,"Size",UDim2.fromOffset(180,60),0.25)
						task.wait(0.05)
						ui_big(b,plr,isOwner)
					elseif d>=EXPAND and state[n] then
						tw(b,"Size",UDim2.fromOffset(32,32),0.25)
						task.wait(0.05)
						ui_small(b,isOwner)
					end
				end
			else
				if boards[n] then
					boards[n]:Destroy()
					boards[n]=nil
				end
			end
		end
	end
end)

print("✅ NihonGo Premium Status Tags v4.0 — LOADED")
print("🌺 Luxury Bloom Edition with Premium Design")
