-- ════════════════════════════════════════════
--   HITBOX CORE
-- ════════════════════════════════════════════
local hitboxEnabled = false
local noCollision   = false
local hitboxSize    = 21
local hitboxTrans   = 6
local hitbox_orig   = {}

local HB_PARTS = {"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}

local function hb_findPart(char, name)
	local low = name:lower()
	for _, p in ipairs(char:GetChildren()) do
		if p:IsA("BasePart") and p.Name:lower() == low then return p end
	end
end

local function hb_save(plr, part)
	if not hitbox_orig[plr] then hitbox_orig[plr] = {} end
	if hitbox_orig[plr][part.Name] then return end
	hitbox_orig[plr][part.Name] = {
		CanCollide   = part.CanCollide,
		Transparency = part.Transparency,
		Size         = part.Size,
	}
end

local function hb_restore(plr)
	local orig = hitbox_orig[plr]
	if not orig then return end
	if plr.Character then
		for name, props in pairs(orig) do
			local p = plr.Character:FindFirstChild(name)
			if p and p:IsA("BasePart") then
				p.CanCollide   = props.CanCollide
				p.Transparency = props.Transparency
				p.Size         = props.Size
			end
		end
	end
	hitbox_orig[plr] = nil
end

local function hb_extend(plr)
	if not plr or not plr.Character then return end
	for _, name in ipairs(HB_PARTS) do
		local p = hb_findPart(plr.Character, name)
		if p then
			hb_save(plr, p)
			p.CanCollide   = not noCollision
			p.Transparency = hitboxTrans / 10
			p.Size         = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
		end
	end
end

local function hb_updateAll()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character then
			if isEnemy(plr) then hb_extend(plr) else hb_restore(plr) end
		end
	end
end

local function hb_restoreAll()
	for _, plr in ipairs(Players:GetPlayers()) do
		hb_restore(plr)
	end
	hitbox_orig = {}
end

local hitboxLoopThread = nil
local function hb_startLoop()
	if hitboxLoopThread then return end
	hitboxLoopThread = task.spawn(function()
		while hitboxEnabled do
			hb_updateAll()
			for plr in pairs(hitbox_orig) do
				if not plr.Parent or not plr.Character then
					hb_restore(plr)
				end
			end
			task.wait(0.05)
		end
		hitboxLoopThread = nil
	end)
end

-- ════════════════════════════════════════════
--   ESP SYSTEM
-- ════════════════════════════════════════════
local espEnabled      = false
local espOutline      = false
local espBox          = false
local espBones        = false
local espTracers      = false
local espNames        = true
local espHP           = true
local espDist         = false
local espTeamColor    = false
local espColor        = Color3.fromRGB(255,180,80)
local espTransparency = 0
local espAlwaysOnTop  = true
local espBoards       = {}

local function destroyESPFor(plr)
	local data = espBoards[plr]; if not data then return end
	pcall(function() if data.hl then data.hl:Destroy() end end)
	pcall(function() if data.bb then data.bb:Destroy() end end)
	pcall(function() if data.tracer then data.tracer:Remove() end end)
	if data.bones then
		for _, d in ipairs(data.bones) do pcall(function() d.line:Remove() end) end
	end
	espBoards[plr] = nil
end

local function getPlayerColor(plr)
	if espTeamColor and plr.TeamColor then return plr.TeamColor.Color end
	return espColor
end

local function buildESPFor(plr)
	if plr == lp or not isEnemy(plr) then return end
	destroyESPFor(plr)
	local char = plr.Character; if not char then return end
	local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	if not head then return end
	local data = {char=char}
	local col  = getPlayerColor(plr)

	if espOutline or espBox then
		local hl = Instance.new("Highlight")
		hl.Name = "NihonESP"
		hl.FillTransparency = espBox and (0.75 + espTransparency*0.25) or 1
		if espBox then hl.FillColor = col end
		hl.OutlineColor = col; hl.OutlineTransparency = espTransparency
		hl.DepthMode = espAlwaysOnTop
			and Enum.HighlightDepthMode.AlwaysOnTop
			or  Enum.HighlightDepthMode.Occluded
		hl.Parent = char; data.hl = hl
	end

	if espBones then
		data.bones = {}
		local joints = {
			{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
			{"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},
			{"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},
			{"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},
			{"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},
			{"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},
			{"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"},
		}
		for _, pair in ipairs(joints) do
			local line = Drawing.new("Line")
			line.Color = col; line.Thickness = 1.5
			line.Transparency = espTransparency; line.Visible = false
			table.insert(data.bones, {line=line, a=pair[1], b=pair[2]})
		end
	end

	if espTracers then
		local line = Drawing.new("Line")
		line.Color = col; line.Thickness = 1.2
		line.Transparency = espTransparency; line.Visible = false
		data.tracer = line
	end

	if espNames or espHP or espDist then
		local bb = Instance.new("BillboardGui")
		bb.Name = "NihonESPTag"; bb.Adornee = head; bb.AlwaysOnTop = espAlwaysOnTop
		bb.Size = UDim2.fromOffset(120,44); bb.StudsOffset = Vector3.new(0,2.8,0)
		bb.ResetOnSpawn = false; bb.Parent = head

		local card = Instance.new("Frame", bb)
		card.Size = UDim2.fromScale(1,1); card.BackgroundColor3 = BLOOM.bgDeep
		card.BackgroundTransparency = 0.28; card.BorderSizePixel = 0
		Instance.new("UICorner", card).CornerRadius = UDim.new(0,6)
		local sk = Instance.new("UIStroke", card)
		sk.Color = col; sk.Thickness = 1.2; sk.Transparency = 0.05

		local nl = Instance.new("TextLabel", card)
		nl.Name = "NameLbl"; nl.Size = UDim2.new(1,-8,0,18)
		nl.Position = UDim2.fromOffset(4,2); nl.BackgroundTransparency = 1
		nl.TextColor3 = col; nl.Font = Enum.Font.GothamBold; nl.TextSize = 11
		nl.TextXAlignment = Enum.TextXAlignment.Center
		nl.TextTruncate = Enum.TextTruncate.AtEnd
		nl.Text = "🌼 "..plr.Name; nl.Visible = espNames

		local barBg = Instance.new("Frame", card)
		barBg.Name = "BarBg"; barBg.Size = UDim2.new(1,-10,0,5)
		barBg.Position = UDim2.new(0,5,0,23)
		barBg.BackgroundColor3 = BLOOM.bar; barBg.BorderSizePixel = 0
		Instance.new("UICorner", barBg).CornerRadius = UDim.new(1,0)
		local bf = Instance.new("Frame", barBg)
		bf.Name = "Fill"; bf.Size = UDim2.fromScale(1,1)
		bf.BackgroundColor3 = col; bf.BorderSizePixel = 0
		Instance.new("UICorner", bf).CornerRadius = UDim.new(1,0)
		barBg.Visible = espHP

		local hpLbl = Instance.new("TextLabel", card)
		hpLbl.Name = "HP"; hpLbl.Size = UDim2.new(1,-8,0,11)
		hpLbl.Position = UDim2.new(0,4,0,30); hpLbl.BackgroundTransparency = 1
		hpLbl.TextColor3 = BLOOM.txtMain; hpLbl.Font = Enum.Font.Gotham
		hpLbl.TextSize = 9; hpLbl.TextXAlignment = Enum.TextXAlignment.Center
		hpLbl.Text = "HP: ?"; hpLbl.Visible = espHP

		data.bb = bb
	end

	espBoards[plr] = data
end

local function updateESPFor(plr)
	local data = espBoards[plr]; if not data then return end
	local char = data.char
	if not char or not char.Parent then destroyESPFor(plr); return end
	if not isEnemy(plr) then destroyESPFor(plr); return end

	local col  = getPlayerColor(plr)
	local hum  = char:FindFirstChildOfClass("Humanoid")
	local hrpT = char:FindFirstChild("HumanoidRootPart")
	local hrpL = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

	if data.hl then
		data.hl.OutlineColor = col
		if espBox then pcall(function() data.hl.FillColor = col end) end
	end

	if data.bb and data.bb.Parent then
		local card = data.bb:FindFirstChildWhichIsA("Frame")
		if card then
			local nl    = card:FindFirstChild("NameLbl")
			local barBg = card:FindFirstChild("BarBg")
			local fill  = barBg and barBg:FindFirstChild("Fill")
			local hpLbl = card:FindFirstChild("HP")
			local sk    = card:FindFirstChildWhichIsA("UIStroke")
			if sk then sk.Color = col end
			if nl then
				nl.Visible = espNames; nl.TextColor3 = col
				nl.Text = (espDist and hrpL and hrpT)
					and ("🌼 "..plr.Name.."  ["..math.floor((hrpL.Position-hrpT.Position).Magnitude).."m]")
					or  ("🌼 "..plr.Name)
			end
			if fill and hpLbl and hum then
				barBg.Visible = espHP; hpLbl.Visible = espHP
				local r = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
				fill.Size = UDim2.fromScale(r, 1)
				fill.BackgroundColor3 = Color3.new(
					math.clamp(2*(1-r),0,1), math.clamp(2*r,0,1), 0.05)
				hpLbl.Text = "HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth)
			end
		end
	end

	if data.bones then
		for _, d in ipairs(data.bones) do
			local pA = char:FindFirstChild(d.a)
			local pB = char:FindFirstChild(d.b)
			if espBones and pA and pB then
				local sA, onA = cam:WorldToViewportPoint(pA.Position)
				local sB, onB = cam:WorldToViewportPoint(pB.Position)
				if onA and onB and sA.Z > 0 and sB.Z > 0 then
					d.line.From = Vector2.new(sA.X, sA.Y)
					d.line.To   = Vector2.new(sB.X, sB.Y)
					d.line.Color = col; d.line.Visible = true
				else d.line.Visible = false end
			else d.line.Visible = false end
		end
	end

	if data.tracer then
		if espTracers and hrpT then
			local sT, onT = cam:WorldToViewportPoint(hrpT.Position)
			if onT and sT.Z > 0 then
				local vp = cam.ViewportSize
				data.tracer.From  = Vector2.new(vp.X/2, vp.Y)
				data.tracer.To    = Vector2.new(sT.X, sT.Y)
				data.tracer.Color = col; data.tracer.Visible = true
			else data.tracer.Visible = false end
		else data.tracer.Visible = false end
	end
end

local function refreshESP()
	if not espEnabled then
		for plr in pairs(espBoards) do destroyESPFor(plr) end
		return
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character and not espBoards[plr] and isEnemy(plr) then
			buildESPFor(plr)
		end
	end
	for plr in pairs(espBoards) do
		if not plr.Parent or not plr.Character or not isEnemy(plr) then
			destroyESPFor(plr)
		end
	end
end

local function rebuildESP()
	if not espEnabled then return end
	for plr in pairs(espBoards) do destroyESPFor(plr) end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character and isEnemy(plr) then buildESPFor(plr) end
	end
end

local function destroyAllESP()
	for plr in pairs(espBoards) do destroyESPFor(plr) end
end

