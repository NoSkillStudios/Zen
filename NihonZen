local function removeBoard(tbl, key)
	if tbl[key] then pcall(function() tbl[key]:Destroy() end); tbl[key] = nil end
	if key and typeof(key) ~= "string" then
		pcall(function()
			local h = key:FindFirstChild("NihonHL"); if h then h:Destroy() end
			local h2 = key:FindFirstChild("NihonObjHL"); if h2 then h2:Destroy() end
		end)
	end
end

local function updateBoard(board, hum)
	if not board or not board.Parent then return end
	local card = board:FindFirstChildWhichIsA("Frame"); if not card then return end
	local bb2 = card:FindFirstChild("BarBg"); local fill = bb2 and bb2:FindFirstChild("Fill")
	local hl = card:FindFirstChild("HP"); if not fill or not hl then return end
	local r = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
	fill.Size = UDim2.fromScale(r,1)
	hl.Text = "HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth)
	fill.BackgroundColor3 = Color3.new(math.clamp(2*(1-r),0,1), math.clamp(2*r,0,1), 0.05)
end

local function refreshZombieESP()
	for m in pairs(zombieESPBoards) do
		local h = m:FindFirstChild("Humanoid")
		if not m.Parent or not h or h.Health <= 0 then
			pcall(function() local hl = m:FindFirstChild("NihonHL"); if hl then hl:Destroy() end end)
			removeBoard(zombieESPBoards, m)
		end
	end
	if not zombieEspEnabled then return end
	for _, npc in ipairs(Workspace:GetChildren()) do
		if npc:IsA("Model") and string.find(string.lower(npc.Name), "zombie") then
			local h = npc:FindFirstChild("Humanoid")
			if h and h.Health > 0 and not zombieESPBoards[npc] then
				local b = makeESPBoard(npc, "🌺 "..npc.Name, BLOOM.espZombie)
				if b then
					zombieESPBoards[npc] = b
					h.Died:Connect(function()
						task.wait(0.1)
						pcall(function() local hl = npc:FindFirstChild("NihonHL"); if hl then hl:Destroy() end end)
						removeBoard(zombieESPBoards, npc)
					end)
				end
			end
		end
	end
end
local function clearZombieESP()
	for m in pairs(zombieESPBoards) do
		pcall(function() local hl = m:FindFirstChild("NihonHL"); if hl then hl:Destroy() end end)
		removeBoard(zombieESPBoards, m)
	end
end

local function refreshPlayerESP()
	for p in pairs(playerESPBoards) do
		if not p.Parent or p == lp then
			if p.Character then pcall(function() local hl = p.Character:FindFirstChild("NihonHL"); if hl then hl:Destroy() end end) end
			removeBoard(playerESPBoards, p)
		end
	end
	if not playerEspEnabled then return end
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp and p.Character and not playerESPBoards[p] then
			local b = makeESPBoard(p.Character, "🌼 "..p.Name, BLOOM.espPlayer)
			if b then playerESPBoards[p] = b end
		end
	end
end
local function clearPlayerESP()
	for p in pairs(playerESPBoards) do
		if p.Character then pcall(function() local hl = p.Character:FindFirstChild("NihonHL"); if hl then hl:Destroy() end end) end
		removeBoard(playerESPBoards, p)
	end
end

local function refreshObjectESP()
	for obj in pairs(objectESPBoards) do
		if not obj.Parent then
			pcall(function() local hl = obj:FindFirstChild("NihonObjHL"); if hl then hl:Destroy() end end)
			removeBoard(objectESPBoards, obj)
		end
	end
	if not objectEspEnabled then return end
	for _, child in ipairs(Workspace:GetChildren()) do
		if not objectESPBoards[child] then
			if child:IsA("Model") or child:IsA("BasePart") then
				local found = false
				for _, v in ipairs(child:GetDescendants()) do
					if v:IsA("Script") and string.lower(v.Name) == "hitdetection" then found = true; break end
				end
				if found then
					local b = makeObjectESP(child)
					if b then objectESPBoards[child] = b end
				end
			end
		end
	end
end
local function clearObjectESP()
	for obj in pairs(objectESPBoards) do
		pcall(function() local hl = obj:FindFirstChild("NihonObjHL"); if hl then hl:Destroy() end end)
		removeBoard(objectESPBoards, obj)
	end
end

