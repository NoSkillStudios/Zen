local k = "NihonLoader_Key_Real"
getgenv()._nl = k
task.wait()

local GAMES = {
	["7398552394"]      = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
	["125224440903394"] = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen",
	["3286380229"]      = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/UnnamedShooter",
	["17887390746"]     = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/UnnamedShooter",
	["9294074907"]      = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap",
	["90568084448279"]  = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap",
}

local function ld(u)
	local s, r = pcall(function()
		return loadstring(game:HttpGet(u))()
	end)
	if not s or not r then return nil end
	return r
end

local placeId = tostring(game.PlaceId)
local scriptUrl = GAMES[placeId]

if not scriptUrl then
	game:GetService("Players").LocalPlayer:Kick("🌺 Nihon Hub — This game is not supported.")
	return
end

local b = ld(scriptUrl.."?v=2")

if not b then
	error("Loader error: script failed to load.")
	return
end

-- Check if it's a function or table
if type(b) == "function" then
	b()
elseif type(b) == "table" then
	if not b._ok then
		error("Loader error: validation failed.")
		return
	end
	if b.init then 
		pcall(b.init)
	end
	if b.start then
		pcall(b.start)
	end
	if b.run then
		pcall(b.run)
	end
else
	print("Script loaded but returned: " .. type(b))
end
