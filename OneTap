	Name="Always On Top", CurrentValue=true,
	Callback=function(v)
		local mode = v and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
		for _, data in pairs(espBoards) do
			if data.hl then data.hl.DepthMode = mode end
		end
	end
})

VisualsTab:CreateSlider({
	Name="ESP Transparency", Range={0,90}, Increment=5, Suffix="%", CurrentValue=0,
	Callback=function(v)
		local t = v / 100
		for _, data in pairs(espBoards) do
			if data.hl then
				data.hl.OutlineTransparency = t
				pcall(function() data.hl.FillTransparency = math.min(1, t + 0.5) end)
			end
			if data.drawings then
				for _, d in ipairs(data.drawings) do d.line.Transparency = t end
			end
		end
	end
})

