local k="NihonLoader_Key_Real"
if getgenv()._nl~=k then return end

local p=game:GetService("Players")
local r=game:GetService("RunService")
local t=game:GetService("TweenService")
local uis=game:GetService("UserInputService")

local lp=p.LocalPlayer
local OWNER="SkibidihhhToiwet"
local SCRIPT_USERS={}
SCRIPT_USERS[lp.Name]=true
local boards={}
local state={}
local EXPAND=30

local COLORS={
	owner=Color3.fromRGB(255,215,100),
	user=Color3.fromRGB(255,140,80),
	bg=Color3.fromRGB(20,18,24),
	text=Color3.fromRGB(255,255,255),
	stroke=Color3.fromRGB(50,50,60),
}

local function tw(o,p2,v,d)
	if not o or not o.Parent then return end
	local i=TweenInfo.new(d,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
	local tw=t:Create(o,i,{[p2]=v})
	tw:Play()
	return tw
end

local function clear(b)
	for _,v in pairs(b:GetChildren()) do
		pcall(function()v:Destroy()end)
	end
end

-- EXPANDED UI - Proper fixed scaling
local function ui_big(b,plr,isOwner)
	clear(b)
	
	local accentColor=isOwner and COLORS.owner or COLORS.user
	
	-- Main card frame
	local mainFrame=Instance.new("Frame",b)
	mainFrame.Name="MainCard"
	mainFrame.Size=UDim2.fromScale(1,1)
	mainFrame.BackgroundColor3=COLORS.bg
	mainFrame.BorderSizePixel=0
	
	local corner=Instance.new("UICorner",mainFrame)
	corner.CornerRadius=UDim.new(0,10)
	
	local stroke=Instance.new("UIStroke",mainFrame)
	stroke.Color=accentColor
	stroke.Thickness=2
	stroke.Transparency=0.2
	
	-- Top bar accent
	local topBar=Instance.new("Frame",mainFrame)
	topBar.Size=UDim2.new(1,0,0,4)
	topBar.BackgroundColor3=accentColor
	topBar.BorderSizePixel=0
	
	-- Icon
	local icon=Instance.new("TextLabel",mainFrame)
	icon.Size=UDim2.fromOffset(35,50)
	icon.Position=UDim2.fromOffset(10,0)
	icon.BackgroundTransparency=1
	icon.Text=isOwner and "🌺" or "🌸"
	icon.TextSize=20
	icon.Font=Enum.Font.Gotham
	icon.TextScaled=true
	
	-- Text container
	local textBox=Instance.new("Frame",mainFrame)
	textBox.Size=UDim2.new(1,-50,1,-4)
	textBox.Position=UDim2.fromOffset(50,4)
	textBox.BackgroundTransparency=1
	
	-- Username
	local nameLabel=Instance.new("TextLabel",textBox)
	nameLabel.Size=UDim2.fromScale(1,0.5)
	nameLabel.BackgroundTransparency=1
	nameLabel.Text=plr.Name
	nameLabel.TextScaled=true
	nameLabel.Font=Enum.Font.GothamBold
	nameLabel.TextColor3=COLORS.text
	nameLabel.TextXAlignment=Enum.TextXAlignment.Left
	nameLabel.TextYAlignment=Enum.TextYAlignment.Bottom
	nameLabel.TextTruncate=Enum.TextTruncate.AtEnd
	
	-- Status
	local statusLabel=Instance.new("TextLabel",textBox)
	statusLabel.Size=UDim2.fromScale(1,0.5)
	statusLabel.Position=UDim2.fromOffset(0,22)
	statusLabel.BackgroundTransparency=1
	statusLabel.Text=isOwner and "👑 OWNER" or "🌱 USER"
	statusLabel.TextScaled=true
	statusLabel.Font=Enum.Font.GothamBold
	statusLabel.TextColor3=accentColor
	statusLabel.TextXAlignment=Enum.TextXAlignment.Left
	statusLabel.TextYAlignment=Enum.TextYAlignment.Top
	
	state[plr.Name]=true
end

-- CIRCLE UI - Compact
local function ui_small(b,isOwner)
	clear(b)
	
	local accentColor=isOwner and COLORS.owner or COLORS.user
	
	local circle=Instance.new("Frame",b)
	circle.Size=UDim2.fromScale(1,1)
	circle.BackgroundColor3=COLORS.bg
	circle.BorderSizePixel=0
	
	local corner=Instance.new("UICorner",circle)
	corner.CornerRadius=UDim.new(1,0)
	
	local stroke=Instance.new("UIStroke",circle)
	stroke.Color=accentColor
	stroke.Thickness=2
	stroke.Transparency=0.15
	
	-- Pulsing dot
	local dot=Instance.new("Frame",circle)
	dot.Name="Dot"
	dot.Size=UDim2.fromOffset(6,6)
	dot.AnchorPoint=Vector2.new(0.5,0.5)
	dot.Position=UDim2.fromScale(0.5,0.5)
	dot.BackgroundColor3=accentColor
	dot.BorderSizePixel=0
	
	local dotCorner=Instance.new("UICorner",dot)
	dotCorner.CornerRadius=UDim.new(1,0)
	
	task.spawn(function()
		while circle and circle.Parent do
			if dot and dot.Parent then
				tw(dot,"Size",UDim2.fromOffset(8,8),0.5)
				task.wait(0.5)
				if dot and dot.Parent then
					tw(dot,"Size",UDim2.fromOffset(6,6),0.5)
					task.wait(0.5)
				end
			end
		end
	end)
	
	state[b.Name]=false
end

-- Create billboard with FIXED SIZE that doesn't scale
local function createBillboard(plr,char,isOwner)
	if plr==lp then return end
	if not SCRIPT_USERS[plr.Name] then return end
	
	local hrp=char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	if boards[plr.Name] then
		pcall(function()boards[plr.Name]:Destroy()end)
	end
	
	-- Create billboard with SCREEN SIZE (not stud-based)
	-- This prevents zoom scaling
	local bill=Instance.new("BillboardGui")
	bill.Name=plr.Name
	bill.Adornee=hrp
	bill.MaxDistance=150
	bill.StudsOffset=Vector3.new(0,3.5,0)
	bill.ResetOnSpawn=false
	bill.AlwaysOnTop=true
	bill.LightInfluence=0
	bill.Parent=hrp
	
	-- Set FIXED SIZE in pixels (not relative to camera)
	bill.Size=UDim2.fromOffset(165,55)
	
	ui_big(bill,plr,isOwner)
	boards[plr.Name]=bill
	print("✅ Tag created: "..plr.Name..(isOwner and " (OWNER)" or " (USER)"))
end

-- Register all existing players as script users
for _,v in pairs(p:GetPlayers()) do
	if v~=lp then
		SCRIPT_USERS[v.Name]=true
		if v.Character then
			local isOwner=v.Name==OWNER
			createBillboard(v,v.Character,isOwner)
		end
		v.CharacterAdded:Connect(function(c)
			SCRIPT_USERS[v.Name]=true
			local isOwner=v.Name==OWNER
			createBillboard(v,c,isOwner)
		end)
	end
end

-- New players
p.PlayerAdded:Connect(function(v)
	if v~=lp then
		SCRIPT_USERS[v.Name]=true
		v.CharacterAdded:Connect(function(c)
			local isOwner=v.Name==OWNER
			createBillboard(v,c,isOwner)
		end)
	end
end)

-- Player leaving
p.PlayerRemoving:Connect(function(v)
	if boards[v.Name] then
		boards[v.Name]:Destroy()
		boards[v.Name]=nil
	end
	SCRIPT_USERS[v.Name]=nil
end)

-- Distance-based UI switching
local lastUpdate=0
r.RenderStepped:Connect(function()
	lastUpdate=lastUpdate+1
	if lastUpdate<10 then return end
	lastUpdate=0
	
	local ch=lp.Character
	local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	for n,b in pairs(boards) do
		if b and b.Parent and b.Adornee then
			local plr=p:FindFirstChild(n)
			if plr and plr.Character then
				local t_hrp=plr.Character:FindFirstChild("HumanoidRootPart")
				if t_hrp then
					local d=(hrp.Position-t_hrp.Position).Magnitude
					local isOwner=plr.Name==OWNER
					
					-- Switch between expanded and circle
					if d<EXPAND and not state[n] then
						-- Switch to expanded
						tw(b,"Size",UDim2.fromOffset(165,55),0.2)
						task.wait(0.1)
						ui_big(b,plr,isOwner)
					elseif d>=EXPAND and state[n] then
						-- Switch to circle
						tw(b,"Size",UDim2.fromOffset(28,28),0.2)
						task.wait(0.1)
						ui_small(b,isOwner)
					end
				end
			else
				if boards[n] then
					boards[n]:Destroy()
					boards[n]=nil
				end
			end
		end
	end
end)

print("✅ NihonGo Status Tags - FIXED v1.0")
print("✅ Zoom scaling fixed")
print("✅ Only showing to script users")
