local k = "NihonLoader_Key_Real"
getgenv()._nl = k

local GAMES = {
	["7398552394"]      = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen.lua",
	["125224440903394"] = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/NihonZen.lua",
	["90568084448279"]  = "https://raw.githubusercontent.com/NoSkillStudios/Zen/main/OneTap.lua",
}

local pid = tostring(game.PlaceId)
if not GAMES[pid] then
	game:GetService("Players").LocalPlayer:Kick("🌺 Nihon Hub — This game is not supported.")
	return
end

local function load_script(url)
	local ok, data = pcall(game.HttpGet, game, url)
	if not ok or not data or data == "" then return nil end
	
	local ok2, result = pcall(loadstring, data)
	if not ok2 or not result then return nil end
	
	local ok3, module = pcall(result)
	if not ok3 or not module or not module._ok then return nil end
	
	return module
end

local v = tostring(math.random(1000000, 9999999))
local sec = load_script("https://raw.githubusercontent.com/NoSkillStudios/Zen/main/SecondScript.lua?v=" .. v)
local main = load_script(GAMES[pid] .. "?v=" .. v)

if not sec or not main then
	error("Loader error: script validation failed.")
	return
end

if sec.init then pcall(sec.init) end
if main.init then pcall(main.init) end
