local espTimer = 0
RunService.RenderStepped:Connect(function(dt)
	local char = lp.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local vp   = cam.ViewportSize
	local cx, cy = vp.X/2, vp.Y/2

	fovCircle.Position = Vector2.new(cx, cy)
	fovCircle.Visible  = aimlockEnabled and aimlockDrawFOV

	local shouldLock = aimlockEnabled
		and (not aimlockHoldOnly or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2))

	if shouldLock then
		local target = getAimlockTarget()
		if target then
			local dir      = (target.Position - cam.CFrame.Position).Unit
			local goalCF   = CFrame.new(cam.CFrame.Position, cam.CFrame.Position + dir)
			local smooth   = math.clamp(aimlockSmooth, 0.01, 1)
			cam.CFrame     = cam.CFrame:Lerp(goalCF, smooth)
		end
	end

	if flingEnabled and hrp then
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= lp and plr.Character and isEnemy(plr) then
				local tHrp = plr.Character:FindFirstChild("HumanoidRootPart")
				if tHrp and (hrp.Position - tHrp.Position).Magnitude <= flingRange then
					tHrp.Velocity = Vector3.new(
						math.random(-300,300), math.random(200,500), math.random(-300,300))
				end
			end
		end
	end

	espTimer += dt
	if espTimer >= 0.5 then espTimer = 0; refreshESP() end
	if espEnabled then
		for plr in pairs(espBoards) do updateESPFor(plr) end
	end
end)

