-- Kill Aura
local killAuraEnabled = false
local killAuraRange   = 20
local TEvent = require(ReplicatedStorage.Shared.Core.TEvent)

local function getTargets()
	local targets = {}
	local myChar  = lp.Character
	local myHead  = myChar and myChar:FindFirstChild("Head")
	if not myHead then return targets end

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == lp then continue end
		local team = plr.Team
		if team and (team == lp.Team or team.Name == "Lobby") then continue end
		local char = plr.Character
		if not char or char:FindFirstChildWhichIsA("ForceField") then continue end
		local hum  = char:FindFirstChildWhichIsA("Humanoid")
		local head = char:FindFirstChild("Head")
		if not head or not hum or hum.Health <= 0 then continue end
		if (head.Position - myHead.Position).Magnitude <= killAuraRange then
			table.insert(targets, { head=head, player=plr, isBot=false })
		end
	end

	for _, bot in ipairs(Workspace:GetChildren()) do
		if not bot:GetAttribute("IsBot") or bot:FindFirstChildWhichIsA("ForceField") then continue end
		local hum  = bot:FindFirstChildWhichIsA("Humanoid")
		local head = bot:FindFirstChild("Head")
		if not head or not hum or hum.Health <= 0 then continue end
		if (head.Position - myHead.Position).Magnitude <= killAuraRange then
			table.insert(targets, { head=head, player=bot, isBot=true })
		end
	end
	return targets
end

local function fireKillAura()
	local targets = getTargets()
	for _, t in ipairs(targets) do
		local playerArg = t.isBot and t.head.Parent or Players:GetPlayerFromCharacter(t.head.Parent)
		local myHead = lp.Character and lp.Character:FindFirstChild("Head")
		if not myHead then break end
		local dir = (t.head.Position - myHead.Position).Unit
		pcall(function()
			TEvent.FireRemote("HookFire", {
				hookId       = 67,
				startPosition = nil,
				direction    = dir,
				distance     = 9e9,
				hookFlyTime  = 0,
				hookBackSpeed = 9e9,
				fireTime     = 0,
			})
			TEvent.FireRemote("HookHit", {
				hookId       = 67,
				targetPlayer = playerArg,
				targetPartName = t.head.Name,
				hookBackSpeed = 9e9,
			})
			TEvent.FireRemote("HookRelease", {
				hookId       = 67,
				targetPlayer = playerArg,
				reason       = "released",
			})
		end)
	end
end

-- Hitbox
local hitboxEnabled = false
local hitboxSize    = 21
local hitboxTrans   = 6
local noCollision   = false
local hitbox_orig   = {}
local HB_PARTS = { "Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso" }

local function hb_save(plr, part)
	if not hitbox_orig[plr] then hitbox_orig[plr] = {} end
	if hitbox_orig[plr][part.Name] then return end
	hitbox_orig[plr][part.Name] = { CanCollide=part.CanCollide, Transparency=part.Transparency, Size=part.Size }
end
local function hb_restore(plr)
	local orig = hitbox_orig[plr]; if not orig then return end
	if plr.Character then
		for name, props in pairs(orig) do
			local p = plr.Character:FindFirstChild(name)
			if p and p:IsA("BasePart") then
				p.CanCollide=props.CanCollide; p.Transparency=props.Transparency; p.Size=props.Size
			end
		end
	end
	hitbox_orig[plr] = nil
end
local function hb_extend(plr)
	if not plr or not plr.Character then return end
	for _, name in ipairs(HB_PARTS) do
		local p = plr.Character:FindFirstChild(name)
		if p and p:IsA("BasePart") then
			hb_save(plr, p)
			p.CanCollide = not noCollision
			p.Transparency = hitboxTrans / 10
			p.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
		end
	end
end
local function hb_updateAll()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character then hb_extend(plr) end
	end
end
local function hb_restoreAll()
	for _, plr in ipairs(Players:GetPlayers()) do hb_restore(plr) end
	hitbox_orig = {}
end
local hbLoopThread = nil
local function hb_startLoop()
	if hbLoopThread then return end
	hbLoopThread = task.spawn(function()
		while hitboxEnabled do hb_updateAll(); task.wait(0.05) end
		hbLoopThread = nil
	end)
end

