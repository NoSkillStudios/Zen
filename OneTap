-- ════════════════════════════════════════════
--   TEAM CHECK HELPER
-- ════════════════════════════════════════════
-- Shared team check used by both hitbox and ESP.
-- "FFA"        = affect everyone
-- "Team-Based" = only affect enemies (different team)
-- "Everyone"   = same as FFA

local teamCheckMode = "FFA"

local function isEnemy(player)
	if teamCheckMode == "FFA" or teamCheckMode == "Everyone" then return true end
	return player.Team ~= lp.Team
end

-- ════════════════════════════════════════════
--   HITBOX SYSTEM
-- ════════════════════════════════════════════
local hitboxEnabled = false
local hitboxSize    = 21
local hitboxTrans   = 6
local hitbox_orig   = {}

local defaultBodyParts = {"UpperTorso","LowerTorso","Torso","Head","HumanoidRootPart"}

local function findExactPart(player, partName)
	if not player.Character then return nil end
	local low = partName:lower()
	for _, p in ipairs(player.Character:GetChildren()) do
		if p:IsA("BasePart") and p.Name:lower() == low then return p end
	end
end

local function savedPart(player, part)
	if not hitbox_orig[player] then hitbox_orig[player] = {} end
	if not hitbox_orig[player][part.Name] then
		hitbox_orig[player][part.Name] = {
			CanCollide   = part.CanCollide,
			Transparency = part.Transparency,
			Size         = part.Size,
		}
	end
end

local function restoredPart(player)
	if not hitbox_orig[player] then return end
	for partName, props in pairs(hitbox_orig[player]) do
		local part = player.Character and player.Character:FindFirstChild(partName)
		if part and part:IsA("BasePart") then
			part.CanCollide   = props.CanCollide
			part.Transparency = props.Transparency
			part.Size         = props.Size
		end
	end
end

local function extendHitbox(player)
	for _, partName in ipairs(defaultBodyParts) do
		local part = findExactPart(player, partName)
		if part then
			savedPart(player, part)
			part.CanCollide   = true
			part.Transparency = hitboxTrans / 10
			part.Size         = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
		end
	end
end

local function updateHitboxes()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= lp and player.Character then
			if isEnemy(player) then
				extendHitbox(player)
			else
				restoredPart(player)
			end
		end
	end
end

local function checkForDeadPlayers()
	for player in pairs(hitbox_orig) do
		if not player.Parent or not player.Character then
			restoredPart(player)
			hitbox_orig[player] = nil
		end
	end
end

-- ════════════════════════════════════════════
--   ESP SYSTEM
-- ════════════════════════════════════════════
local espEnabled = false
local espMethod  = "Outline"
local espColor   = Color3.fromRGB(255, 180, 80)
local espBoards  = {}

local BGDEEP = Color3.fromRGB(28, 16, 10)
local BARCLR = Color3.fromRGB(45, 25, 12)
local TXTCLR = Color3.fromRGB(255, 230, 200)

local function destroyESPFor(plr)
	local data = espBoards[plr]; if not data then return end
	pcall(function() data.bb:Destroy() end)
	if data.hl then pcall(function() data.hl:Destroy() end) end
	if data.drawings then
		for _, d in ipairs(data.drawings) do pcall(function() d.line:Remove() end) end
	end
	espBoards[plr] = nil
end

local function buildESPFor(plr)
	if plr == lp then return end
	-- Respect team check — only build for enemies
	if not isEnemy(plr) then return end
	destroyESPFor(plr)
	local char = plr.Character; if not char then return end
	local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	if not head then return end

	local data = {char = char}

	if espMethod == "Outline" then
		local hl = Instance.new("Highlight")
		hl.Name = "NihonESP"; hl.FillTransparency = 1
		hl.OutlineColor = espColor; hl.OutlineTransparency = 0
		hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		hl.Parent = char; data.hl = hl

	elseif espMethod == "Box" then
		local hl = Instance.new("Highlight")
		hl.Name = "NihonESP"
		hl.FillColor = espColor; hl.FillTransparency = 0.75
		hl.OutlineColor = espColor; hl.OutlineTransparency = 0.1
		hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		hl.Parent = char; data.hl = hl

	elseif espMethod == "Bones" then
		data.drawings = {}
		local joints = {
			{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
			{"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},
			{"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},
			{"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},
			{"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},
			{"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},
			{"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"},
		}
		for _, pair in ipairs(joints) do
			local line = Drawing.new("Line")
			line.Color = espColor; line.Thickness = 1.5
			line.Transparency = 0; line.Visible = false
			table.insert(data.drawings, {line=line, a=pair[1], b=pair[2]})
		end
	end

	-- Shared billboard + HP bar
	local bb = Instance.new("BillboardGui")
	bb.Name="NihonESPTag"; bb.Adornee=head; bb.AlwaysOnTop=true
	bb.Size=UDim2.fromOffset(120,44); bb.StudsOffset=Vector3.new(0,2.8,0)
	bb.ResetOnSpawn=false; bb.Parent=head

	local card = Instance.new("Frame", bb)
	card.Size=UDim2.fromScale(1,1); card.BackgroundColor3=BGDEEP
	card.BackgroundTransparency=0.28; card.BorderSizePixel=0
	Instance.new("UICorner",card).CornerRadius=UDim.new(0,6)
	local sk=Instance.new("UIStroke",card)
	sk.Color=espColor; sk.Thickness=1.2; sk.Transparency=0.05

	local nl=Instance.new("TextLabel",card)
	nl.Size=UDim2.new(1,-8,0,18); nl.Position=UDim2.fromOffset(4,2)
	nl.BackgroundTransparency=1; nl.TextColor3=espColor
	nl.Font=Enum.Font.GothamBold; nl.TextSize=11
	nl.TextXAlignment=Enum.TextXAlignment.Center
	nl.TextTruncate=Enum.TextTruncate.AtEnd
	nl.Text="🌼 "..plr.Name

	local barBg=Instance.new("Frame",card)
	barBg.Name="BarBg"; barBg.Size=UDim2.new(1,-10,0,5)
	barBg.Position=UDim2.new(0,5,0,23)
	barBg.BackgroundColor3=BARCLR; barBg.BorderSizePixel=0
	Instance.new("UICorner",barBg).CornerRadius=UDim.new(1,0)
	local bf=Instance.new("Frame",barBg)
	bf.Name="Fill"; bf.Size=UDim2.fromScale(1,1)
	bf.BackgroundColor3=espColor; bf.BorderSizePixel=0
	Instance.new("UICorner",bf).CornerRadius=UDim.new(1,0)

	local hpLbl=Instance.new("TextLabel",card)
	hpLbl.Name="HP"; hpLbl.Size=UDim2.new(1,-8,0,11)
	hpLbl.Position=UDim2.new(0,4,0,30)
	hpLbl.BackgroundTransparency=1; hpLbl.TextColor3=TXTCLR
	hpLbl.Font=Enum.Font.Gotham; hpLbl.TextSize=9
	hpLbl.TextXAlignment=Enum.TextXAlignment.Center; hpLbl.Text="HP: ?"

	data.bb = bb
	espBoards[plr] = data
end

local function updateESPFor(plr)
	local data = espBoards[plr]; if not data then return end
	local char = data.char
	if not char or not char.Parent then destroyESPFor(plr); return end

	-- If player switched to same team, remove ESP
	if not isEnemy(plr) then destroyESPFor(plr); return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum and data.bb and data.bb.Parent then
		local card  = data.bb:FindFirstChildWhichIsA("Frame")
		local barBg = card and card:FindFirstChild("BarBg")
		local fill  = barBg and barBg:FindFirstChild("Fill")
		local hpL   = card and card:FindFirstChild("HP")
		if fill and hpL then
			local r = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
			fill.Size = UDim2.fromScale(r,1)
			fill.BackgroundColor3 = Color3.new(
				math.clamp(2*(1-r),0,1),
				math.clamp(2*r,0,1),
				0.05
			)
			hpL.Text = "HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth)
		end
	end

	if data.drawings then
		local cam = workspace.CurrentCamera
		for _, d in ipairs(data.drawings) do
			local pA = char:FindFirstChild(d.a)
			local pB = char:FindFirstChild(d.b)
			if pA and pB then
				local sA, onA = cam:WorldToViewportPoint(pA.Position)
				local sB, onB = cam:WorldToViewportPoint(pB.Position)
				if onA and onB and sA.Z > 0 and sB.Z > 0 then
					d.line.From    = Vector2.new(sA.X, sA.Y)
					d.line.To      = Vector2.new(sB.X, sB.Y)
					d.line.Color   = espColor
					d.line.Visible = true
				else
					d.line.Visible = false
				end
			else
				d.line.Visible = false
			end
		end
	end
end

local function refreshESP()
	if not espEnabled then
		for plr in pairs(espBoards) do destroyESPFor(plr) end
		return
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character and not espBoards[plr] then
			if isEnemy(plr) then buildESPFor(plr) end
		end
	end
	-- Remove ESP from players that are now teammates
	for plr in pairs(espBoards) do
		if not plr.Parent or not plr.Character or not isEnemy(plr) then
			destroyESPFor(plr)
		end
	end
end

