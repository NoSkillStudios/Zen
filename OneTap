		plr.CharacterAdded:Connect(function()
			task.wait(0.5)
			if espEnabled and isEnemy(plr) then buildESPFor(plr) end
		end)
	end
end

lp.CharacterAdded:Connect(function()
	task.wait(1)
	if ghostEnabled then setGhost(true) end
end)

