local function buildFeatRows(lines)
	for _, r in ipairs(featRowRefs) do pcall(function() r:Destroy() end) end
	featRowRefs = {}
	for i, f in ipairs(lines) do
		local row = Instance.new("Frame", FeatScroll)
		row.Size = UDim2.new(1,0,0,24); row.LayoutOrder = i
		row.BackgroundColor3 = Color3.fromRGB(28,15,7)
