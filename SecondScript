	wrap.BorderSizePixel        = 0
	Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 7)
	local wStroke = Instance.new("UIStroke", wrap)
	wStroke.Color = Color3.fromRGB(65, 34, 12); wStroke.Thickness = 1

	local iconRow = Instance.new("Frame", wrap)
	iconRow.Size               = UDim2.new(1, 0, 0, 40)
	iconRow.BackgroundTransparency = 1
	local iconLbl = Instance.new("TextLabel", iconRow)
	iconLbl.Size               = UDim2.fromScale(1, 1)
	iconLbl.BackgroundTransparency = 1
	iconLbl.Text               = "🗝️"
	iconLbl.TextSize           = 20
	iconLbl.Font               = Enum.Font.Gotham
	iconLbl.TextXAlignment     = Enum.TextXAlignment.Center

	local hint = Instance.new("TextLabel", wrap)
	hint.Size               = UDim2.new(1, -20, 0, 14)
	hint.Position           = UDim2.fromOffset(10, 40)
	hint.BackgroundTransparency = 1
	hint.TextColor3         = Color3.fromRGB(85, 50, 18)
	hint.Font               = Enum.Font.Gotham
	hint.TextSize           = 10
	hint.TextXAlignment     = Enum.TextXAlignment.Center
	hint.Text               = "Enter key below  ·  Hint: check the script source"

	local box = Instance.new("TextBox", wrap)
	box.Size               = UDim2.new(1, -20, 0, 30)
	box.Position           = UDim2.fromOffset(10, 58)
	box.BackgroundColor3   = Color3.fromRGB(12, 7, 3)
	box.BorderSizePixel    = 0
	box.TextColor3         = Color3.fromRGB(230, 185, 130)
	box.PlaceholderColor3  = Color3.fromRGB(90, 52, 20)
	box.Font               = Enum.Font.GothamSemibold
	box.TextSize           = 13
	box.PlaceholderText    = "Enter key..."
	box.Text               = ""
	box.ClearTextOnFocus   = true
	box.TextXAlignment     = Enum.TextXAlignment.Center
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)
	local bStroke = Instance.new("UIStroke", box)
	bStroke.Color = Color3.fromRGB(75, 40, 14); bStroke.Thickness = 1; bStroke.Transparency = 0.2
	box.Focused:Connect(function()
		TweenService:Create(bStroke, TweenInfo.new(0.14), {Color=Color3.fromRGB(210, 115, 40), Transparency=0}):Play()
	end)
	box.FocusLost:Connect(function()
		TweenService:Create(bStroke, TweenInfo.new(0.14), {Color=Color3.fromRGB(75, 40, 14), Transparency=0.2}):Play()
	end)

	local status = Instance.new("TextLabel", wrap)
	status.Size               = UDim2.new(1, -20, 0, 14)
	status.Position           = UDim2.fromOffset(10, 94)
	status.BackgroundTransparency = 1
	status.TextColor3         = Color3.fromRGB(100, 60, 22)
	status.Font               = Enum.Font.Gotham
	status.TextSize           = 10
	status.Text               = ""
	status.TextXAlignment     = Enum.TextXAlignment.Center

	local confirmBtn = mkBtn(panel, 174, 452, 0, "Confirm Key  →", true)

	local passed, attempts = false, 0

	local function shake()
		local orig = box.Position
		for _ = 1, 4 do
			TweenService:Create(box, TweenInfo.new(0.04), {Position=orig+UDim2.fromOffset(6,0)}):Play(); task.wait(0.04)
			TweenService:Create(box, TweenInfo.new(0.04), {Position=orig+UDim2.fromOffset(-6,0)}):Play(); task.wait(0.04)
		end
		TweenService:Create(box, TweenInfo.new(0.04), {Position=orig}):Play()
	end

	local function tryKey()
		if passed then return end
		local valid = false
		for _, kv in ipairs(VALID_KEYS) do if box.Text == kv then valid = true; break end end
		if valid then
			passed = true
			TweenService:Create(bStroke, TweenInfo.new(0.15), {Color=BLOOM.keyOk}):Play()
			TweenService:Create(box, TweenInfo.new(0.15), {TextColor3=BLOOM.keyOk}):Play()
			TweenService:Create(wStroke, TweenInfo.new(0.2), {Color=BLOOM.keyOk}):Play()
			status.TextColor3 = BLOOM.keyOk; status.Text = "✓  Key accepted"
			TweenService:Create(confirmBtn, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(40, 155, 65)}):Play()
			task.wait(0.55)
			if onPass then onPass() end
		else
			attempts += 1; shake()
			TweenService:Create(bStroke, TweenInfo.new(0.1), {Color=BLOOM.keyErr}):Play()
			TweenService:Create(box, TweenInfo.new(0.1), {TextColor3=BLOOM.keyErr}):Play()
			TweenService:Create(wStroke, TweenInfo.new(0.1), {Color=BLOOM.keyErr}):Play()
			status.TextColor3 = BLOOM.keyErr
			status.Text = attempts >= 3 and ("✗  Invalid  ·  "..attempts.." attempts") or "✗  Invalid key"
			task.wait(0.75)
			TweenService:Create(bStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(75, 40, 14), Transparency=0.2}):Play()
			TweenService:Create(box, TweenInfo.new(0.2), {TextColor3=Color3.fromRGB(230, 185, 130)}):Play()
			TweenService:Create(wStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(65, 34, 12)}):Play()
			box.Text = ""
		end
	end

	confirmBtn.MouseButton1Click:Connect(tryKey)
	box.FocusLost:Connect(function(enter) if enter then tryKey() end end)
	return panel
end

petalConn = RunService.RenderStepped:Connect(function(dt)
