VisualsTab:CreateColorPicker({Name="ESP Color", Color=Color3.fromRGB(255,180,80),
	Callback=function(c)
		espColor = c
		for _, data in pairs(espBoards) do
			if data.hl then
				data.hl.OutlineColor = c
				pcall(function() data.hl.FillColor = c end)
			end
			if data.bones then for _, d in ipairs(data.bones) do d.line.Color = c end end
			if data.tracer then data.tracer.Color = c end
			if data.bb and data.bb.Parent then
				local card = data.bb:FindFirstChildWhichIsA("Frame")
				if card then
					local sk = card:FindFirstChildWhichIsA("UIStroke"); if sk then sk.Color = c end
					local nl = card:FindFirstChild("NameLbl");           if nl then nl.TextColor3 = c end
					local bg = card:FindFirstChild("BarBg")
					local fl = bg and bg:FindFirstChild("Fill");         if fl then fl.BackgroundColor3 = c end
				end
			end
		end
	end})
VisualsTab:CreateSlider({Name="ESP Transparency", Range={0,90}, Increment=5, Suffix="%", CurrentValue=0,
	Callback=function(v)
		espTransparency = v / 100
		for _, data in pairs(espBoards) do
			if data.hl then
				data.hl.OutlineTransparency = espTransparency
				pcall(function() data.hl.FillTransparency = math.min(1, espTransparency+0.5) end)
			end
			if data.bones then for _, d in ipairs(data.bones) do d.line.Transparency = espTransparency end end
			if data.tracer then data.tracer.Transparency = espTransparency end
		end
	end})
