		ColorSequenceKeypoint.new(0, statusColor),
		ColorSequenceKeypoint.new(0.5, statusColor),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 50, 20)),
	})
	glowGrad.Rotation = 90
	
	-- Icon
	local iconLabel = Instance.new("TextLabel", card)
	iconLabel.Name = "Icon"
	iconLabel.Size = UDim2.fromOffset(26, 52)
	iconLabel.Position = UDim2.fromOffset(12, 0)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Text = statusIcon
	iconLabel.TextSize = 18
	iconLabel.Font = Enum.Font.Gotham
	iconLabel.TextColor3 = statusColor
	
	-- Status text with name
	local textContainer = Instance.new("Frame", card)
	textContainer.Size = UDim2.new(1, -56, 1, -8)
	textContainer.Position = UDim2.fromOffset(46, 4)
	textContainer.BackgroundTransparency = 1
	textContainer.BorderSizePixel = 0
	
	local statusLabel = Instance.new("TextLabel", textContainer)
	statusLabel.Name = "StatusLabel"
	statusLabel.Size = UDim2.fromScale(1, 0.5)
	statusLabel.BackgroundTransparency = 1
	statusLabel.TextColor3 = statusColor
	statusLabel.Font = Enum.Font.GothamBold
	statusLabel.TextSize = 10
	statusLabel.TextXAlignment = Enum.TextXAlignment.Left
	statusLabel.TextYAlignment = Enum.TextYAlignment.Bottom
