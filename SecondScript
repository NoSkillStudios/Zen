local k="NihonLoader_Key_Real"
if getgenv()._nl~=k then return end

local p=game:GetService("Players")
local r=game:GetService("RunService")
local t=game:GetService("TweenService")
local lp=p.LocalPlayer
local OWNER="SkibidihhhToiwet"
local users={}
users[lp.Name]=true
local boards={}
local state={}
local EXPAND=35

local COLORS={
	owner_main=Color3.fromRGB(255,215,100),
	owner_dark=Color3.fromRGB(180,140,60),
	user_main=Color3.fromRGB(255,140,80),
	user_dark=Color3.fromRGB(180,100,50),
	bg_dark=Color3.fromRGB(12,12,15),
	bg_light=Color3.fromRGB(25,25,30),
	stroke=Color3.fromRGB(50,50,60),
	text=Color3.fromRGB(240,240,245),
}

local function tw(o,p2,v,d)
	local i=TweenInfo.new(d,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
	local tw=t:Create(o,i,{[p2]=v})
	tw:Play()
	return tw
end

local function createGradient(parent,rot)
	local grad=Instance.new("UIGradient",parent)
	grad.Rotation=rot or 45
	return grad
end

local function clear(b)
	for _,v in pairs(b:GetChildren()) do
		pcall(function()v:Destroy()end)
	end
end

