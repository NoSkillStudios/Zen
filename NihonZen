local oneFoodActive = false
local oneFoodOriginals = {}
local oneFoodConns = {}

local function hookFeedModel(model)
	local feed = model:FindFirstChild("feed")
	if not feed or not feed:IsA("NumberValue") then return end
	if oneFoodConns[model] then return end
	if not oneFoodOriginals[model] then
		oneFoodOriginals[model] = feed.Value
	end
	feed.Value = 100
	oneFoodConns[model] = RunService.Heartbeat:Connect(function()
		if not oneFoodActive then return end
		if feed and feed.Parent then feed.Value = 100 end
	end)
end

local function unhookFeedModel(model)
	if oneFoodConns[model] then
		oneFoodConns[model]:Disconnect()
		oneFoodConns[model] = nil
	end
	local feed = model:FindFirstChild("feed")
	if feed and feed:IsA("NumberValue") and oneFoodOriginals[model] ~= nil then
		feed.Value = oneFoodOriginals[model]
	end
	oneFoodOriginals[model] = nil
end

local oneFoodDescConn = nil

MiscTab:CreateToggle({Name="One Food Fill Hunger", CurrentValue=false,
	Callback=function(v)
		oneFoodActive = v
		if v then
			for _, model in ipairs(Workspace:GetDescendants()) do
				if model:IsA("Model") then
					hookFeedModel(model)
				end
			end
			oneFoodDescConn = Workspace.DescendantAdded:Connect(function(inst)
				if not oneFoodActive then return end
				if inst:IsA("Model") then
					hookFeedModel(inst)
				end
				if inst:IsA("NumberValue") and inst.Name == "feed" and inst.Parent:IsA("Model") then
					hookFeedModel(inst.Parent)
				end
			end)
		else
			if oneFoodDescConn then oneFoodDescConn:Disconnect(); oneFoodDescConn = nil end
			for model in pairs(oneFoodConns) do
				unhookFeedModel(model)
			end
		end
	end})

