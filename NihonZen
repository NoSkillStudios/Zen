local petals = {}
local function spawnPetal()
	local c = Drawing.new("Circle")
	local cols = { BLOOM.petal1, BLOOM.petal2, BLOOM.petal3, BLOOM.petal4 }
	c.Color = cols[math.random(1, #cols)]
	c.Filled = true; c.NumSides = 20
	c.Radius = math.random(2, 5); c.Thickness = 1
	c.Transparency = math.random(55, 78) * 0.01
	local vp = workspace.CurrentCamera.ViewportSize
	c.Position = Vector2.new(math.random(0, vp.X), math.random(-40, 0))
	table.insert(petals, { obj=c, vx=math.random(-10,10)*0.1, vy=math.random(30,65)*0.1 })
end

