-- JavaScript execution function
local function executeJS(jsCode)
	local success, result = pcall(function()
		if syn and syn.run_js then
			return syn.run_js(jsCode)
		elseif WebSocket then
			-- Fallback for environments with WebSocket
			return loadstring(jsCode)()
		else
			error("No JavaScript execution environment available")
		end
	end)
	
	if not success then
		warn("JavaScript execution failed: " .. tostring(result))
		return nil
	end
	return result
end

