--   AIMLOCK
-- ════════════════════════════════════════════
local aimlockEnabled  = false
local aimlockSmooth   = 0.18
local aimlockFOV      = 120
local aimlockBone     = "Head"
local aimlockHoldOnly = false
local aimlockDrawFOV  = true

local fovCircle           = Drawing.new("Circle")
fovCircle.Visible         = false
fovCircle.Filled          = false
fovCircle.Color           = Color3.fromRGB(255, 180, 80)
fovCircle.Thickness       = 1.4
fovCircle.NumSides        = 64
fovCircle.Transparency    = 0.35
fovCircle.Radius          = 120

local function getAimlockTarget()
	local vp     = cam.ViewportSize
	local center = Vector2.new(vp.X/2, vp.Y/2)
	local best, bestDist = nil, aimlockFOV

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= lp and plr.Character and isEnemy(plr) then
			local hum = plr.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local bone = plr.Character:FindFirstChild(aimlockBone)
					or plr.Character:FindFirstChild("Head")
					or plr.Character:FindFirstChild("HumanoidRootPart")
				if bone then
					local sp, onScreen = cam:WorldToViewportPoint(bone.Position)
					if onScreen and sp.Z > 0 then
						local screenPos = Vector2.new(sp.X, sp.Y)
						local dist = (screenPos - center).Magnitude
						if dist < bestDist then
							bestDist = dist
							best     = bone
						end
					end
				end
			end
		end
	end
	return best
end

-- ════════════════════════════════════════════
--   CHARACTER HOOKS — respawn + new joiners
-- ════════════════════════════════════════════
local function applyToChar(plr)
	if not plr or plr == lp then return end
	if not isEnemy(plr) then return end
	if espEnabled then
		destroyESPFor(plr)
		buildESPFor(plr)
	end
	if hitboxEnabled then
		hitbox_orig[plr] = nil
		hb_extend(plr)
	end
end

local function hookPlayer(plr)
	plr.CharacterAdded:Connect(function(char)
		char:WaitForChild("HumanoidRootPart", 6)
		task.wait(0.6)
		applyToChar(plr)
	end)
	if plr.Character then
		task.defer(applyToChar, plr)
	end
end

Players.PlayerRemoving:Connect(function(plr)
	destroyESPFor(plr)
	hb_restore(plr)
end)

Players.PlayerAdded:Connect(hookPlayer)

for _, plr in ipairs(Players:GetPlayers()) do
	if plr ~= lp then hookPlayer(plr) end
end

lp.CharacterAdded:Connect(function()
	task.wait(1)
	if ghostEnabled   then setGhost(true)    end
	if flyEnabled     then startFly()        end
	if noclipEnabled  then startNoclip()     end
end)

