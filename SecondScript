local function createCircleUI(billboard, isOwner)
	billboard.Size = UDim2.fromOffset(32, 32)
	billboard.MaxDistance = 150
	
	-- Clear existing
	for _, child in ipairs(billboard:GetChildren()) do
		child:Destroy()
	end
	
	local statusColor = isOwner and BLOOM.owner or BLOOM.user
	
	-- Outer circle frame
	local circleContainer = Instance.new("Frame", billboard)
	circleContainer.Name = "CircleContainer"
	circleContainer.Size = UDim2.fromScale(1, 1)
	circleContainer.BackgroundColor3 = BLOOM.bgDeep
	circleContainer.BackgroundTransparency = 0.15
	circleContainer.BorderSizePixel = 0
	
	local circleCorner = Instance.new("UICorner", circleContainer)
	circleCorner.CornerRadius = UDim.new(1, 0)
	
	-- Circle stroke
	local circleStroke = Instance.new("UIStroke", circleContainer)
	circleStroke.Color = statusColor
	circleStroke.Thickness = 2
	circleStroke.Transparency = 0.2
	
	-- Inner pulsing dot
	local innerDot = Instance.new("Frame", circleContainer)
	innerDot.Name = "InnerDot"
	innerDot.Size = UDim2.fromOffset(8, 8)
	innerDot.AnchorPoint = Vector2.new(0.5, 0.5)
	innerDot.Position = UDim2.fromScale(0.5, 0.5)
	innerDot.BackgroundColor3 = statusColor
	innerDot.BorderSizePixel = 0
	
	local dotCorner = Instance.new("UICorner", innerDot)
	dotCorner.CornerRadius = UDim.new(1, 0)
	
	-- Pulsing animation loop
	task.spawn(function()
		while circleContainer.Parent do
			local pulse1 = tweenProperty(innerDot, "Size", UDim2.fromOffset(10, 10), 0.6)
			if pulse1 then
				pulse1.Completed:Connect(function()
					if circleContainer.Parent then
						tweenProperty(innerDot, "Size", UDim2.fromOffset(8, 8), 0.6)
					end
				end)
			end
			task.wait(1.2)
		end
	end)
	
	expandedStates[billboard.Parent.Parent.Name] = false
end

local function createStatusBoard(player, character)
	if not character or player == lp then return end
	
	-- Only show for script users
	if not SCRIPT_USERS[player.Name] then return end
	
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoidRootPart then return end
	
	-- Destroy old billboard if exists
	if statusBoards[player.Name] then
		pcall(function() statusBoards[player.Name]:Destroy() end)
	end
	
	local isOwner = player.Name == SkibidihhhToiwet
	
	-- Create billboard
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "NihonAdvancedStatus_" .. player.Name
	billboard.Adornee = humanoidRootPart
	billboard.MaxDistance = 150
	billboard.StudsOffset = Vector3.new(0, 3.5, 0)
	billboard.ResetOnSpawn = false
	billboard.Parent = humanoidRootPart
	
	-- Start with expanded
	createExpandedUI(billboard, player, character, isOwner)
	
	statusBoards[player.Name] = billboard
end

local function updateBillboardDistance(playerName, distance, isOwner)
	local billboard = statusBoards[playerName]
	if not billboard or not billboard.Parent then return end
	
	local wasExpanded = expandedStates[playerName]
	local shouldBeExpanded = distance < DISTANCE_EXPANDED
	
	if shouldBeExpanded ~= wasExpanded then
		if shouldBeExpanded then
			-- Animate to expanded
			tweenProperty(billboard, "Size", UDim2.fromOffset(160, 52), 0.3)
			task.wait(0.05)
			createExpandedUI(billboard, Players:FindFirstChild(playerName), 
				Players:FindFirstChild(playerName).Character, isOwner)
		else
			-- Animate to circle
			tweenProperty(billboard, "Size", UDim2.fromOffset(32, 32), 0.3)
			task.wait(0.05)
			createCircleUI(billboard, isOwner)
		end
	elseif not shouldBeExpanded and distance >= DISTANCE_EXPANDED then
		-- Smooth transition while circle
		local circleFactor = math.min((distance - DISTANCE_EXPANDED) / (DISTANCE_TRANSITION - DISTANCE_EXPANDED), 1)
		if billboard:FindFirstChild("CircleContainer") then
			local circle = billboard:FindFirstChild("CircleContainer")
			circle.BackgroundTransparency = 0.15 + (circleFactor * 0.35)
		end
	end
end

local function destroyBoard(playerName)
	if statusBoards[playerName] then
		pcall(function() statusBoards[playerName]:Destroy() end)
		statusBoards[playerName] = nil
		expandedStates[playerName] = nil
	end
end

local function onPlayerAdded(player)
	if player == lp then return end
	
	-- Create board if character exists
	if player.Character then
		createStatusBoard(player, player.Character)
	end
	
	-- Connect to future character spawns
	player.CharacterAdded:Connect(function(character)
		createStatusBoard(player, character)
	end)
end

local function onPlayerRemoving(player)
	destroyBoard(player.Name)
	SCRIPT_USERS[player.Name] = nil
end

-- Register local player
SCRIPT_USERS[lp.Name] = true

-- Connect to existing players (except self)
for _, player in ipairs(Players:GetPlayers()) do
	if player ~= lp then
		onPlayerAdded(player)
	end
end

-- Connect to new players
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

-- Main update loop for distance-based scaling and animations
RunService.RenderStepped:Connect(function()
	local lp_char = lp.Character
	local lp_hrp = lp_char and lp_char:FindFirstChild("HumanoidRootPart")
	
	if not lp_hrp then return end
	
	for playerName, billboard in pairs(statusBoards) do
		if billboard and billboard.Parent then
			local player = Players:FindFirstChild(playerName)
			if player and player.Character then
				local target_hrp = player.Character:FindFirstChild("HumanoidRootPart")
				if target_hrp then
					local distance = (lp_hrp.Position - target_hrp.Position).Magnitude
					local isOwner = player.Name == OWNER_NAME
					
					-- Update distance-based scaling
					updateBillboardDistance(playerName, distance, isOwner)
					
					-- Fade out at extreme distance
					local fadeStart = 140
					if distance > fadeStart then
						local fadeAlpha = math.max(0, 1 - (distance - fadeStart) / 10)
						local card = billboard:FindFirstChild("Card")
						local circle = billboard:FindFirstChild("CircleContainer")
						
						if card then card.BackgroundTransparency = 0.12 + (1 - fadeAlpha) * 0.5 end
						if circle then circle.BackgroundTransparency = 0.15 + (1 - fadeAlpha) * 0.5 end
					end
				end
			else
				destroyBoard(playerName)
			end
		else
			destroyBoard(playerName)
		end
	end
end)

-- Cleanup on script termination
local shutdown = function()
	for playerName in pairs(statusBoards) do
		destroyBoard(playerName)
	end
end

