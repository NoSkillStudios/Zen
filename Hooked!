		Instance.new("UICorner", row).CornerRadius = UDim.new(0,4)
		local ic = Instance.new("TextLabel", row)
		ic.Size = UDim2.fromOffset(22,24); ic.BackgroundTransparency = 1
		ic.Text = f.icon; ic.TextSize = 11; ic.Font = Enum.Font.Gotham
		local tx = Instance.new("TextLabel", row)
		tx.Size = UDim2.new(1,-26,1,0); tx.Position = UDim2.fromOffset(22,0)
		tx.BackgroundTransparency = 1; tx.TextColor3 = Color3.fromRGB(175,118,65)
		tx.Font = Enum.Font.Gotham; tx.TextSize = 10
		tx.TextXAlignment = Enum.TextXAlignment.Left
		tx.Text = f.text; tx.TextTruncate = Enum.TextTruncate.AtEnd
		table.insert(featRowRefs, row)
	end
	FeatScroll.CanvasSize = UDim2.fromOffset(0, fsList.AbsoluteContentSize.Y + 8)
end
