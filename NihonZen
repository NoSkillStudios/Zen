				task.wait(0.5)
				siLbl.Text = "Step 4 of 4"
				slideOut(KeyPanel, LoadPanel)
			else
				attempts += 1; shakeBox()
				TweenService:Create(kbStroke, TweenInfo.new(0.1), {Color=BLOOM.keyErr}):Play()
				TweenService:Create(KeyBox, TweenInfo.new(0.1), {TextColor3=BLOOM.keyErr}):Play()
				TweenService:Create(keyCardStroke, TweenInfo.new(0.1), {Color=BLOOM.keyErr}):Play()
				KeyStatus.TextColor3 = BLOOM.keyErr
				KeyStatus.Text = attempts >= 3 and ("✗  Invalid  ·  "..attempts.." attempts") or "✗  Invalid key"
				task.wait(0.75)
				TweenService:Create(kbStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(75, 40, 14), Transparency=0.2}):Play()
				TweenService:Create(KeyBox, TweenInfo.new(0.2), {TextColor3=Color3.fromRGB(230, 185, 130)}):Play()
				TweenService:Create(keyCardStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(65, 34, 12)}):Play()
				KeyBox.Text = ""
			end
		end
		KeyBtn.MouseButton1Click:Connect(tryKey)
		KeyBox.FocusLost:Connect(function(enter) if enter then tryKey() end end)
		repeat task.wait(0.05) until keyPassed
	end
end

