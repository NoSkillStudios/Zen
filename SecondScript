local k="NihonLoader_Key_Real"
if getgenv()._nl~=k then return end

local p=game:GetService("Players")
local r=game:GetService("RunService")
local t=game:GetService("TweenService")
local cam=workspace.CurrentCamera

local lp=p.LocalPlayer
local OWNER="SkibidihhhToiwet"
local EXPAND_DIST=35
local BASE_DIST=20

local C={
	owner=Color3.fromRGB(255,200,80),
	user=Color3.fromRGB(120,180,255),
	bg=Color3.fromRGB(14,13,18),
	bgrim=Color3.fromRGB(22,20,28),
	text=Color3.fromRGB(235,235,240),
	stroke_o=Color3.fromRGB(255,190,60),
	stroke_u=Color3.fromRGB(90,150,240),
}

if not getgenv()._nihon_executors then
	getgenv()._nihon_executors={}
end
getgenv()._nihon_executors[lp.Name]=true

local boards={}
local expanded={}

local function isExec(name)
	return getgenv()._nihon_executors[name]==true
end

local function clearKids(inst)
	for _,v in inst:GetChildren() do v:Destroy() end
end

local function mkCorner(par,rad)
	local c=Instance.new("UICorner",par)
	c.CornerRadius=UDim.new(0,rad)
end

local function mkStroke(par,col,thick,trans)
	local s=Instance.new("UIStroke",par)
	s.Color=col s.Thickness=thick s.Transparency=trans or 0
end

local function buildExpanded(bill,plr,isOwner)
	clearKids(bill)
	local ac=isOwner and C.owner or C.user
	local sc=isOwner and C.stroke_o or C.stroke_u

	local root=Instance.new("Frame",bill)
	root.Size=UDim2.fromScale(1,1)
	root.BackgroundColor3=C.bg
	root.BorderSizePixel=0
	mkCorner(root,12)
	mkStroke(root,sc,1.5,0.1)

	local grad=Instance.new("UIGradient",root)
	grad.Color=ColorSequence.new{
		ColorSequenceKeypoint.new(0,C.bgrim),
		ColorSequenceKeypoint.new(1,C.bg)
	}
	grad.Rotation=135

	local bar=Instance.new("Frame",root)
	bar.Size=UDim2.new(1,0,0,3)
	bar.BackgroundColor3=ac
	bar.BorderSizePixel=0
	mkCorner(bar,12)

	local shine=Instance.new("Frame",root)
	shine.Size=UDim2.new(0.4,0,0,1)
	shine.Position=UDim2.new(0.3,0,0,2)
	shine.BackgroundColor3=Color3.fromRGB(255,255,255)
	shine.BackgroundTransparency=0.7
	shine.BorderSizePixel=0
	mkCorner(shine,4)

	local icon=Instance.new("TextLabel",root)
	icon.Size=UDim2.fromOffset(40,52)
	icon.Position=UDim2.new(0,8,0,3)
	icon.BackgroundTransparency=1
	icon.Text=isOwner and "👑" or "✦"
	icon.TextSize=isOwner and 22 or 16
	icon.Font=Enum.Font.Gotham
	icon.TextColor3=ac
	icon.TextXAlignment=Enum.TextXAlignment.Center
	icon.TextYAlignment=Enum.TextYAlignment.Center

	local right=Instance.new("Frame",root)
	right.Size=UDim2.new(1,-54,1,-4)
	right.Position=UDim2.new(0,50,0,3)
	right.BackgroundTransparency=1

	local nameLabel=Instance.new("TextLabel",right)
	nameLabel.Size=UDim2.new(1,0,0,26)
	nameLabel.Position=UDim2.new(0,0,0,6)
	nameLabel.BackgroundTransparency=1
	nameLabel.Text=plr.Name..(isOwner and " 👑" or " ✦")
	nameLabel.Font=Enum.Font.GothamBold
	nameLabel.TextSize=13
	nameLabel.TextColor3=C.text
	nameLabel.TextXAlignment=Enum.TextXAlignment.Left
	nameLabel.TextTruncate=Enum.TextTruncate.AtEnd
	nameLabel.ClipsDescendants=true

	local badge=Instance.new("Frame",right)
	badge.Size=UDim2.new(0,isOwner and 68 or 52,0,16)
	badge.Position=UDim2.new(0,0,0,30)
	badge.BackgroundColor3=ac
	badge.BackgroundTransparency=0.82
	badge.BorderSizePixel=0
	mkCorner(badge,6)
	mkStroke(badge,ac,1,0.4)

	local badgeTxt=Instance.new("TextLabel",badge)
	badgeTxt.Size=UDim2.fromScale(1,1)
	badgeTxt.BackgroundTransparency=1
	badgeTxt.Text=isOwner and "OWNER" or "USER"
	badgeTxt.Font=Enum.Font.GothamBold
	badgeTxt.TextSize=9
	badgeTxt.TextColor3=ac
	badgeTxt.TextXAlignment=Enum.TextXAlignment.Center

	expanded[plr.Name]=true
end

local function buildDot(bill,isOwner)
	clearKids(bill)
	local ac=isOwner and C.owner or C.user

	local ring=Instance.new("Frame",bill)
	ring.Size=UDim2.fromScale(1,1)
	ring.BackgroundColor3=C.bg
	ring.BackgroundTransparency=0.1
	ring.BorderSizePixel=0
	mkCorner(ring,50)
	mkStroke(ring,ac,1.5,0.2)

	local dot=Instance.new("Frame",ring)
	dot.Name="d"
	dot.Size=UDim2.fromOffset(8,8)
	dot.AnchorPoint=Vector2.new(0.5,0.5)
	dot.Position=UDim2.fromScale(0.5,0.5)
	dot.BackgroundColor3=ac
	dot.BorderSizePixel=0
	mkCorner(dot,50)

	local alive=true
	task.spawn(function()
		while alive and ring.Parent do
			local ti=TweenInfo.new(0.6,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut)
			t:Create(dot,ti,{Size=UDim2.fromOffset(10,10)}):Play()
			task.wait(0.6)
			t:Create(dot,ti,{Size=UDim2.fromOffset(6,6)}):Play()
			task.wait(0.6)
		end
	end)

	ring.Destroying:Connect(function() alive=false end)
	expanded[bill.Name]=false
end

local function makeBoard(plr,char,isOwner)
	local hrp=char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	if boards[plr.Name] then
		pcall(function() boards[plr.Name]:Destroy() end)
		boards[plr.Name]=nil
	end

	local bill=Instance.new("BillboardGui")
	bill.Name=plr.Name
	bill.Adornee=hrp
	bill.MaxDistance=200
	bill.StudsOffset=Vector3.new(0,3.2,0)
	bill.ResetOnSpawn=false
	bill.AlwaysOnTop=false
	bill.LightInfluence=0
	bill.SizeOffset=Vector2.zero
	bill.Size=UDim2.fromOffset(180,58)
	bill.Parent=hrp

	buildExpanded(bill,plr,isOwner)
	boards[plr.Name]=bill
end

local function hookPlayer(plr)
	if plr==lp then return end
	if not isExec(plr.Name) then return end

	local isOwner=plr.Name==OWNER
	if plr.Character then
		task.defer(makeBoard,plr,plr.Character,isOwner)
	end
	plr.CharacterAdded:Connect(function(c)
		task.wait()
		makeBoard(plr,c,isOwner)
	end)
end

for _,plr in ipairs(p:GetPlayers()) do
	hookPlayer(plr)
end

p.PlayerAdded:Connect(hookPlayer)

p.PlayerRemoving:Connect(function(plr)
	if boards[plr.Name] then
		boards[plr.Name]:Destroy()
		boards[plr.Name]=nil
	end
	expanded[plr.Name]=nil
	getgenv()._nihon_executors[plr.Name]=nil
end)

local frame=0
r.RenderStepped:Connect(function()
	frame+=1

	local lch=lp.Character
	local lhrp=lch and lch:FindFirstChild("HumanoidRootPart")

	for n,bill in pairs(boards) do
		if not bill or not bill.Parent then
			boards[n]=nil
			continue
		end
		local adorn=bill.Adornee
		if not adorn or not adorn.Parent then
			bill:Destroy()
			boards[n]=nil
			continue
		end

		local dist=lhrp and (lhrp.Position-adorn.Position).Magnitude or 999

		if frame%2==0 then
			local wantExpand=dist<EXPAND_DIST
			if wantExpand and not expanded[n] then
				local plr=p:FindFirstChild(n)
				if plr then buildExpanded(bill,plr,n==OWNER) end
			elseif not wantExpand and expanded[n] then
				buildDot(bill,n==OWNER)
			end
		end

		local fov=cam.FieldOfView
		local scale=math.clamp(math.tan(math.rad(fov/2))*dist/BASE_DIST,0.5,3.5)

		if expanded[n] then
			bill.Size=UDim2.fromOffset(180*scale,58*scale)
		else
			bill.Size=UDim2.fromOffset(30*scale,30*scale)
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(3)
		for n,_ in pairs(getgenv()._nihon_executors) do
			local plr=p:FindFirstChild(n)
			if plr and plr~=lp and not boards[n] then
				hookPlayer(plr)
			end
		end
	end
end)
