local espTimer = 0
RunService.RenderStepped:Connect(function(dt)
	local char = lp.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if brakeLoop then
		pcall(function()
			ReplicatedStorage:WaitForChild("toggle"):FireServer(
				Workspace:WaitForChild("car"):WaitForChild("Misc"):WaitForChild("pbrake"):WaitForChild("h")
			)
		end)
	end
	if carDragLoop then
		pcall(function()
			local car = Workspace:FindFirstChild("car")
			if car then ReplicatedStorage.dragcar:FireServer(Vector3.new(0.472,-0.550,0.688), car.Body.rear.paint, Vector3.new(-2187.3,60.09,-782.8)) end
		end)
	end
	if flingEnabled and hrp then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= lp and p.Character then
				local tHrp = p.Character:FindFirstChild("HumanoidRootPart")
				if tHrp and (hrp.Position - tHrp.Position).Magnitude <= flingRange then
					tHrp.Velocity = Vector3.new(math.random(-300,300), math.random(200,500), math.random(-300,300))
				end
			end
		end
	end
	for _, npc in ipairs(Workspace:GetChildren()) do
		if npc:IsA("Model") and string.find(string.lower(npc.Name), "zombie") then
			local hum = npc:FindFirstChild("Humanoid"); local tHrp = npc:FindFirstChild("HumanoidRootPart")
			if tHrp and hum then
				if hitboxesEnabled then
					tHrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
					tHrp.Transparency = 0.7; tHrp.CanCollide = false
				else
					tHrp.Size = Vector3.new(2,2,1); tHrp.Transparency = 1
				end
				if killAuraEnabled and hrp and hum.Health > 0 then
					if (hrp.Position - tHrp.Position).Magnitude <= killAuraRange then hum.Health = 0 end
				end
			end
		end
	end
	local pg = lp:FindFirstChild("PlayerGui")
	if pg then
		local main = pg:FindFirstChild("main")
		if main then
			if infStamina and main:FindFirstChild("stamina") then main.stamina.Value = 999999; main.stamina.MaxValue = 999999 end
			if infHunger  and main:FindFirstChild("hunger")  then main.hunger.Value  = 999999; main.hunger.MaxValue  = 999999 end
		end
	end
	espTimer += dt
	if espTimer >= 0.5 then espTimer = 0; refreshZombieESP(); refreshPlayerESP(); refreshObjectESP() end
	if zombieEspEnabled then
		for m, b in pairs(zombieESPBoards) do local h = m:FindFirstChild("Humanoid"); if h then updateBoard(b,h) end end
	end
	if playerEspEnabled then
		for p, b in pairs(playerESPBoards) do
			if p.Character then local h = p.Character:FindFirstChild("Humanoid"); if h then updateBoard(b,h) end end
		end
	end
end)
