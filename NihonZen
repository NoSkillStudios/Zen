			autoRunConn = RunService.Heartbeat:Connect(function()
				if not autoRunActive then
					autoRunConn:Disconnect(); autoRunConn = nil; return
				end
				local run = getRunValue()
				if run and run:IsA("BoolValue") then run.Value = true end
			end)
		else
