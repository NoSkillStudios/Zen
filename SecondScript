local BLOOM = {
	bg         = Color3.fromRGB(18, 12, 8),
	bgDeep     = Color3.fromRGB(28, 16, 10),
	bgMid      = Color3.fromRGB(22, 14, 9),
	panel      = Color3.fromRGB(36, 22, 14),
	accent     = Color3.fromRGB(255, 140, 80),
	accentSoft = Color3.fromRGB(255, 190, 130),
	accentGlow = Color3.fromRGB(255, 210, 160),
	owner      = Color3.fromRGB(255, 215, 100),
	user       = Color3.fromRGB(255, 140, 80),
	divider    = Color3.fromRGB(70, 40, 20),
}

-- Distance-based scaling
local DISTANCE_EXPANDED = 40      -- Show full UI within this distance
local DISTANCE_TRANSITION = 60    -- Start transitioning to circle
local DISTANCE_CIRCLE = 120       -- Show only circle beyond this

local statusBoards = {}
local expandedStates = {}         -- Track which billboards are expanded

-- Register this user as a script user
SCRIPT_USERS[lp.Name] = true

-- Listen for other script users
local remoteChannel = Instance.new("RemoteEvent")
remoteChannel.Name = "NihonStatusChannel"
remoteChannel.Parent = workspace
remoteChannel.OnServerEvent:Connect(function(player)
	SCRIPT_USERS[player.Name] = true
end)

local function broadcastPresence()
	pcall(function()
		remoteChannel:FireServer()
	end)
end

task.spawn(function()
	while true do
		task.wait(2)
		broadcastPresence()
	end
end)

local function tweenProperty(obj, prop, targetValue, duration)
	if not obj or not obj.Parent then return end
	local info = TweenInfo.new(
		duration,
		Enum.EasingStyle.Quad,
		Enum.EasingDirection.InOut
	)
	local tween = TweenService:Create(obj, info, {[prop] = targetValue})
	tween:Play()
	return tween
end

local function createExpandedUI(billboard, player, character, isOwner)
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoidRootPart then return end
	
	billboard.Size = UDim2.fromOffset(160, 52)
	billboard.MaxDistance = 150
	
	-- Clear existing
	for _, child in ipairs(billboard:GetChildren()) do
		child:Destroy()
	end
	
	local statusText = isOwner and "👑 Owner" or "🌱 User"
	local statusIcon = isOwner and "🌺" or "🌸"
	local statusColor = isOwner and BLOOM.owner or BLOOM.user
	
	-- Main card
	local card = Instance.new("Frame", billboard)
	card.Name = "Card"
	card.Size = UDim2.fromScale(1, 1)
	card.BackgroundColor3 = BLOOM.bgDeep
	card.BackgroundTransparency = 0.12
	card.BorderSizePixel = 0
	
	local cardCorner = Instance.new("UICorner", card)
	cardCorner.CornerRadius = UDim.new(0, 10)
	
	-- Backdrop blur effect (using gradient for bloom aesthetic)
	local backdropGrad = Instance.new("UIGradient", card)
	backdropGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 20, 10)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 15, 8)),
	})
	backdropGrad.Rotation = 45
	
	-- Premium stroke
	local cardStroke = Instance.new("UIStroke", card)
	cardStroke.Color = statusColor
	cardStroke.Thickness = 1.8
	cardStroke.Transparency = 0.15
	
	-- Top accent line with glow
	local topAccent = Instance.new("Frame", card)
	topAccent.Name = "TopAccent"
	topAccent.Size = UDim2.new(1, 0, 0, 2.5)
	topAccent.BackgroundColor3 = statusColor
	topAccent.BorderSizePixel = 0
	
	local accentGrad = Instance.new("UIGradient", topAccent)
	accentGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, statusColor),
		ColorSequenceKeypoint.new(0.5, statusColor),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 60, 20)),
	})
	
	-- Left glow bar
	local glowBar = Instance.new("Frame", card)
	glowBar.Name = "GlowBar"
	glowBar.Size = UDim2.new(0, 3.5, 1, -5)
	glowBar.Position = UDim2.new(0, 4, 0, 2.5)
