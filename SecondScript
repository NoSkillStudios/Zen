local function mkBtn(parent, yPos, w, xOff, txt, primary)
	local b = Instance.new("TextButton", parent)
	b.Size             = UDim2.fromOffset(w, 34)
	b.Position         = UDim2.fromOffset(xOff, yPos)
	b.BackgroundColor3 = primary and Color3.fromRGB(200, 100, 30) or Color3.fromRGB(30, 18, 8)
	b.BorderSizePixel  = 0
	b.AutoButtonColor  = false
	b.TextColor3       = primary and Color3.fromRGB(18, 9, 3) or Color3.fromRGB(175, 105, 45)
	b.Font             = Enum.Font.GothamBold
	b.TextSize         = 12
	b.Text             = txt
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
	if primary then
		local g = Instance.new("UIGradient", b)
		g.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(240, 140, 55)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(195, 85, 20)),
		})
		g.Rotation = 90
	else
		local s = Instance.new("UIStroke", b)
		s.Color = Color3.fromRGB(70, 40, 16); s.Thickness = 1; s.Transparency = 0.3
	end
	b.MouseEnter:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.13), {
			BackgroundColor3 = primary and Color3.fromRGB(225, 120, 45) or Color3.fromRGB(40, 24, 10)
		}):Play()
	end)
	b.MouseLeave:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.13), {
			BackgroundColor3 = primary and Color3.fromRGB(200, 100, 30) or Color3.fromRGB(30, 18, 8)
		}):Play()
	end)
	return b
end

local function slideOut(from, to)
	TweenService:Create(from, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position=UDim2.fromOffset(-16, 0)}):Play()
	task.wait(0.16)
	from.Visible  = false
	from.Position = UDim2.fromScale(0, 0)
	to.Position   = UDim2.fromOffset(16, 0)
	to.Visible    = true
	TweenService:Create(to, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position=UDim2.fromOffset(0, 0)}):Play()
end

local function dismissGui()
	for _, child in ipairs(Card:GetDescendants()) do
		if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
			TweenService:Create(child, TweenInfo.new(0.22), {TextTransparency=1}):Play()
		end
		if child:IsA("Frame") or child:IsA("ScrollingFrame") then
			pcall(function() TweenService:Create(child, TweenInfo.new(0.22), {BackgroundTransparency=1}):Play() end)
		end
		if child:IsA("UIStroke") then
			TweenService:Create(child, TweenInfo.new(0.22), {Transparency=1}):Play()
		end
	end
	task.wait(0.24)
	TweenService:Create(Card, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
		Size     = UDim2.fromOffset(480, 0),
		Position = UDim2.new(0.5, -240, 0.5, 180),
		BackgroundTransparency = 1,
	}):Play()
	task.wait(0.3)
	TweenService:Create(Bg, TweenInfo.new(0.32, Enum.EasingStyle.Quad), {BackgroundTransparency=1}):Play()
	TweenService:Create(glow, TweenInfo.new(0.32), {BackgroundTransparency=1}):Play()
	task.wait(0.36)
	if petalConn then petalConn:Disconnect() end
	for _, p in ipairs(petals) do pcall(function() p.obj:Remove() end) end
	petals = {}
	GuiRoot:Destroy()
	resolved = true
end

local function buildKeyPanel(parent, onPass)
	local panel = Instance.new("Frame", parent)
	panel.Size               = UDim2.fromScale(1, 1)
	panel.BackgroundTransparency = 1
	panel.Visible            = false

	mkSecLabel(panel, 0, "Access Key")
