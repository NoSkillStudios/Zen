local function makeGameBtn(game, index)
	local btn = Instance.new("TextButton", Body)
	btn.Size                  = UDim2.new(1, 0, 0, 58)
	btn.LayoutOrder           = index
	btn.BackgroundColor3      = Color3.fromRGB(22, 12, 5)
	btn.BorderSizePixel       = 0
	btn.AutoButtonColor       = false
	btn.Text                  = ""
	btn.ZIndex                = 4
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
	local stroke = Instance.new("UIStroke", btn)
	stroke.Color       = Color3.fromRGB(60, 32, 10)
	stroke.Thickness   = 1
	stroke.Transparency = 0.4

	-- Icon box
	local iconBox = Instance.new("Frame", btn)
	iconBox.Size             = UDim2.fromOffset(42, 42)
	iconBox.Position         = UDim2.fromOffset(10, 8)
	iconBox.BackgroundColor3 = game.color
	iconBox.BackgroundTransparency = 0.82
	iconBox.BorderSizePixel  = 0
	iconBox.ZIndex           = 5
	Instance.new("UICorner", iconBox).CornerRadius = UDim.new(0, 8)
	local iconStroke = Instance.new("UIStroke", iconBox)
	iconStroke.Color       = game.color
	iconStroke.Thickness   = 1
	iconStroke.Transparency = 0.5
	local iconLbl = Instance.new("TextLabel", iconBox)
	iconLbl.Size                 = UDim2.fromScale(1, 1)
	iconLbl.BackgroundTransparency = 1
	iconLbl.Text                 = game.icon
	iconLbl.TextSize             = 20
	iconLbl.Font                 = Enum.Font.Gotham
	iconLbl.ZIndex               = 6

	-- Separator
	local sep = Instance.new("Frame", btn)
	sep.Size             = UDim2.fromOffset(1, 30)
	sep.Position         = UDim2.fromOffset(62, 14)
	sep.BackgroundColor3 = Color3.fromRGB(60, 32, 10)
	sep.BorderSizePixel  = 0
	sep.ZIndex           = 5

	-- Name
	local nameLbl = Instance.new("TextLabel", btn)
	nameLbl.Size                 = UDim2.new(1, -120, 0, 22)
	nameLbl.Position             = UDim2.fromOffset(72, 9)
	nameLbl.BackgroundTransparency = 1
	nameLbl.TextColor3           = Color3.fromRGB(235, 190, 135)
	nameLbl.Font                 = Enum.Font.GothamBold
	nameLbl.TextSize             = 14
	nameLbl.TextXAlignment       = Enum.TextXAlignment.Left
	nameLbl.Text                 = game.name
	nameLbl.ZIndex               = 5

	local descLbl = Instance.new("TextLabel", btn)
	descLbl.Size                 = UDim2.new(1, -120, 0, 13)
	descLbl.Position             = UDim2.fromOffset(72, 32)
	descLbl.BackgroundTransparency = 1
	descLbl.TextColor3           = Color3.fromRGB(95, 58, 22)
	descLbl.Font                 = Enum.Font.Gotham
	descLbl.TextSize             = 10
	descLbl.TextXAlignment       = Enum.TextXAlignment.Left
	descLbl.Text                 = game.desc
	descLbl.ZIndex               = 5

	-- Arrow
	local arrow = Instance.new("TextLabel", btn)
	arrow.Size                 = UDim2.fromOffset(20, 58)
	arrow.Position             = UDim2.new(1, -28, 0, 0)
	arrow.BackgroundTransparency = 1
	arrow.TextColor3           = Color3.fromRGB(70, 38, 12)
	arrow.Font                 = Enum.Font.GothamBold
	arrow.TextSize             = 18
	arrow.Text                 = "›"
	arrow.ZIndex               = 5

	-- Hover
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn,    TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(32, 18, 7)}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.15), {Color=game.color, Transparency=0}):Play()
		TweenService:Create(arrow,  TweenInfo.new(0.15), {TextColor3=game.color}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn,    TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(22, 12, 5)}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.15), {Color=Color3.fromRGB(60,32,10), Transparency=0.4}):Play()
		TweenService:Create(arrow,  TweenInfo.new(0.15), {TextColor3=Color3.fromRGB(70,38,12)}):Play()
	end)

	-- Click
	btn.MouseButton1Click:Connect(function()
		-- Animate out
		TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3=game.color, BackgroundTransparency=0.7}):Play()
		task.wait(0.18)
		TweenService:Create(Card, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
			Position               = UDim2.new(0.5, 0, 0.5, 30),
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(Backdrop, TweenInfo.new(0.25), {BackgroundTransparency=1}):Play()
		task.wait(0.28)
		ScreenGui:Destroy()

		-- Fetch script content first so we can see HTTP errors separately
		local content, fetchErr = nil, nil
		local fetchOk = pcall(function()
			content = game:HttpGet(game.url)
		end)
		if not fetchOk or not content or content == "" then
			pcall(function()
				game:GetService("StarterGui"):SetCore("SendNotification", {
					Title    = "Nihon Hub — Fetch Error",
					Text     = "Could not download: " .. game.url,
					Duration = 10,
				})
			end)
			return
		end

		-- Execute
		local ok, err = pcall(function()
			loadstring(content)()
		end)
		if not ok then
			pcall(function()
				game:GetService("StarterGui"):SetCore("SendNotification", {
					Title    = "Nihon Hub — Script Error",
					Text     = tostring(err),
					Duration = 10,
				})
			end)
		end
	end)

	return btn
end

for i, g in ipairs(GAMES) do
	makeGameBtn(g, i)
end
