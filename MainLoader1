-- Improved function with retry logic and better error handling
local function safeLoad(url, maxRetries)
	maxRetries = maxRetries or 3
	local lastError
	
	for attempt = 1, maxRetries do
		local success, result = pcall(function()
			local response = game:HttpGet(url, true)
			if not response or response == "" then
				error("Empty response from server")
			end
			local fn = loadstring(response)
			if not fn then
				error("Failed to parse script")
			end
			return fn()
		end)
		
		if success then
			return result
		end
		
		lastError = result
		if attempt < maxRetries then
			task.wait(0.5 * attempt) -- exponential backoff
		end
	end
	
	warn("Failed to load " .. url .. " after " .. maxRetries .. " attempts: " .. tostring(lastError))
	return nil
end

