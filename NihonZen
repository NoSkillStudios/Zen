local function slideOut(from, to)
	TweenService:Create(from, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position=UDim2.fromOffset(-16, 0)}):Play()
	task.wait(0.16)
	from.Visible = false; from.Position = UDim2.fromScale(0,0)
	to.Position = UDim2.fromOffset(16, 0); to.Visible = true
	TweenService:Create(to, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position=UDim2.fromOffset(0,0)}):Play()
end

local petalTimer = 0
local petalConn = RunService.RenderStepped:Connect(function(dt)
	petalTimer += dt
	if petalTimer > 0.12 and #petals < 22 then petalTimer = 0; spawnPetal() end
	local vp = workspace.CurrentCamera.ViewportSize
	for i = #petals, 1, -1 do
		local p = petals[i]
		p.obj.Position += Vector2.new(p.vx, p.vy) * dt * 16
		if p.obj.Position.Y > vp.Y + 20 then p.obj:Remove(); table.remove(petals, i) end
	end
end)

